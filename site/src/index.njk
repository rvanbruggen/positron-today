---
layout: base.njk
title: Home
---

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.75rem; font-weight: 700; color: #78350f; margin-bottom: 0.25rem; }
  .page-header p { font-size: 0.9rem; color: #b45309; }
  .lang-tabs { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; }
  .lang-tab {
    padding: 0.35rem 0.85rem; border-radius: 99px; font-size: 0.8rem;
    font-weight: 600; cursor: pointer; border: none;
    background: #fef3c7; color: #92400e; transition: background 0.15s;
  }
  .lang-tab.active { background: #facc15; color: #78350f; }
  .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }
  .card {
    border-radius: 1rem; padding: 1.25rem;
    border: 2px solid transparent;
    text-decoration: none;
    display: flex; flex-direction: column; gap: 0.5rem;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.10); }
  .card-topic { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.7; }
  .card-title { font-size: 0.95rem; font-weight: 600; line-height: 1.4; }
  .card-summary { font-size: 0.825rem; line-height: 1.55; opacity: 0.85; }
  .card-meta { font-size: 0.7rem; opacity: 0.6; margin-top: auto; padding-top: 0.5rem; display: flex; justify-content: space-between; }
  .card-emoji { font-size: 1.5rem; }
  .empty { color: #b45309; font-size: 0.9rem; }

  /* Color palette for cards */
  .card-yellow  { background: #fef9c3; border-color: #fde047; color: #713f12; }
  .card-orange  { background: #ffedd5; border-color: #fb923c; color: #7c2d12; }
  .card-rose    { background: #ffe4e6; border-color: #fb7185; color: #881337; }
  .card-purple  { background: #f3e8ff; border-color: #c084fc; color: #581c87; }
  .card-blue    { background: #dbeafe; border-color: #60a5fa; color: #1e3a5f; }
  .card-cyan    { background: #cffafe; border-color: #22d3ee; color: #164e63; }
  .card-teal    { background: #ccfbf1; border-color: #2dd4bf; color: #134e4a; }
  .card-green   { background: #dcfce7; border-color: #4ade80; color: #14532d; }
  .card-lime    { background: #ecfccb; border-color: #a3e635; color: #365314; }
  .card-pink    { background: #fce7f3; border-color: #f472b6; color: #831843; }
</style>

<div class="page-header">
  <h1>Positive news, every day ✨</h1>
  <p>A curated selection of good things happening in the world.</p>
</div>

<div class="lang-tabs">
  <button class="lang-tab active" onclick="setLang('en', this)">EN</button>
  <button class="lang-tab" onclick="setLang('nl', this)">NL</button>
  <button class="lang-tab" onclick="setLang('fr', this)">FR</button>
</div>

{% if collections.posts.length == 0 %}
  <p class="empty">No posts yet - check back soon!</p>
{% else %}
  <div class="card-grid">
    {% for post in collections.posts %}
    <a href="{{ post.url | url }}" class="card card-{{ loop.index | cardColor }}">
      <div class="card-emoji">{{ post.data.emoji }}</div>
      <div class="card-topic">{{ post.data.topic }}</div>
      <div class="card-title">
        <span class="t-en">{{ post.data.title }}</span>
        <span class="t-nl" style="display:none">{{ post.data.title_nl if post.data.title_nl else post.data.title }}</span>
        <span class="t-fr" style="display:none">{{ post.data.title_fr if post.data.title_fr else post.data.title }}</span>
      </div>
      {% if post.data.summary %}
      <div class="card-summary">
        <span class="t-en">{{ post.data.summary }}</span>
        <span class="t-nl" style="display:none">{{ post.data.summary_nl if post.data.summary_nl else post.data.summary }}</span>
        <span class="t-fr" style="display:none">{{ post.data.summary_fr if post.data.summary_fr else post.data.summary }}</span>
      </div>
      {% endif %}
      <div class="card-meta">
        <span>{{ post.data.source_name }}</span>
        <span>{{ post.date | dateDisplay }}</span>
      </div>
    </a>
    {% endfor %}
  </div>
{% endif %}

<script>
  const LANGS = ['en', 'nl', 'fr'];
  function setLang(lang, btn) {
    LANGS.forEach(function(l) {
      document.querySelectorAll('.t-' + l).forEach(function(el) {
        el.style.display = l === lang ? '' : 'none';
      });
    });
    document.querySelectorAll('.lang-tab').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    localStorage.setItem('positiviteiten-lang', lang);
  }
  (function() {
    var saved = localStorage.getItem('positiviteiten-lang');
    if (saved && saved !== 'en') {
      var btn = document.querySelector('.lang-tab[onclick*="' + saved + '"]');
      if (btn) setLang(saved, btn);
    }
  })();
</script>
