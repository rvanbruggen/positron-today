---
layout: base.njk
title: Home
---

<style>
  .page-header { margin-bottom: 1.25rem; }
  .page-header h1 { font-size: clamp(1.35rem, 5vw, 1.75rem); font-weight: 700; color: #78350f; margin-bottom: 0.25rem; }
  .page-header p { font-size: 0.875rem; color: #b45309; }

  /* ── Filter bar ── */
  .filter-bar { display: flex; gap: 0.6rem; margin-bottom: 1.25rem; align-items: center; flex-wrap: wrap; }

  /* Tag picker */
  .tag-picker { position: relative; }
  .tag-picker-btn {
    padding: 0.4rem 0.85rem; border-radius: 99px; font-size: 0.8rem;
    font-weight: 600; cursor: pointer; border: 2px solid #fde68a;
    background: #fef9c3; color: #78350f; transition: all 0.15s;
    white-space: nowrap; -webkit-tap-highlight-color: transparent;
  }
  .tag-picker-btn.has-selection { background: #facc15; border-color: #f59e0b; }
  .tag-picker-panel {
    display: none; position: absolute; top: calc(100% + 0.4rem); left: 0;
    background: white; border: 1.5px solid #fde68a; border-radius: 1rem;
    padding: 0.75rem; z-index: 100; min-width: 260px; max-width: 340px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.10);
  }
  .tag-picker-panel.open { display: block; }
  .tag-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .tag-chip {
    padding: 0.3rem 0.7rem; border-radius: 99px; font-size: 0.75rem;
    font-weight: 600; cursor: pointer; border: 2px solid transparent;
    transition: all 0.15s; white-space: nowrap;
    -webkit-tap-highlight-color: transparent;
  }
  .tag-chip.selected { border-color: currentColor; box-shadow: 0 0 0 2px rgba(0,0,0,0.08); }
  .tag-chip-all { background: #fef3c7; color: #92400e; }
  .tag-chip-all.selected { background: #facc15; border-color: #f59e0b; color: #78350f; }

  /* Date-range select (replaces month select) */
  .date-range-select {
    padding: 0.4rem 0.75rem; border-radius: 0.6rem; font-size: 0.8rem;
    font-weight: 600; border: 2px solid #fde68a; background: #fef9c3;
    color: #78350f; cursor: pointer; font-family: inherit;
  }
  .date-range-select:focus { outline: none; border-color: #f59e0b; }
  .date-range-select.has-selection { background: #facc15; border-color: #f59e0b; }

  /* Clear button */
  .filter-clear {
    padding: 0.35rem 0.7rem; border-radius: 99px; font-size: 0.75rem;
    font-weight: 600; cursor: pointer; border: none;
    background: transparent; color: #b45309; text-decoration: underline;
  }

  /* Tag chip colour palette (same as old tbtn-*) */
  .tchip-yellow { background:#fef9c3; color:#713f12; } .tchip-yellow.selected { background:#fde047; }
  .tchip-orange { background:#ffedd5; color:#7c2d12; } .tchip-orange.selected { background:#fb923c; }
  .tchip-rose   { background:#ffe4e6; color:#881337; } .tchip-rose.selected   { background:#fb7185; }
  .tchip-purple { background:#f3e8ff; color:#581c87; } .tchip-purple.selected { background:#c084fc; }
  .tchip-blue   { background:#dbeafe; color:#1e3a5f; } .tchip-blue.selected   { background:#60a5fa; }
  .tchip-cyan   { background:#cffafe; color:#164e63; } .tchip-cyan.selected   { background:#22d3ee; }
  .tchip-teal   { background:#ccfbf1; color:#134e4a; } .tchip-teal.selected   { background:#2dd4bf; }
  .tchip-green  { background:#dcfce7; color:#14532d; } .tchip-green.selected  { background:#4ade80; }
  .tchip-lime   { background:#ecfccb; color:#365314; } .tchip-lime.selected   { background:#a3e635; }
  .tchip-pink   { background:#fce7f3; color:#831843; } .tchip-pink.selected   { background:#f472b6; }

  /* Card colours (unchanged) */
  .tbtn-yellow { background:#fef9c3; color:#713f12; }
  .tbtn-orange { background:#ffedd5; color:#7c2d12; }
  .tbtn-rose   { background:#ffe4e6; color:#881337; }
  .tbtn-purple { background:#f3e8ff; color:#581c87; }
  .tbtn-blue   { background:#dbeafe; color:#1e3a5f; }
  .tbtn-cyan   { background:#cffafe; color:#164e63; }
  .tbtn-teal   { background:#ccfbf1; color:#134e4a; }
  .tbtn-green  { background:#dcfce7; color:#14532d; }
  .tbtn-lime   { background:#ecfccb; color:#365314; }
  .tbtn-pink   { background:#fce7f3; color:#831843; }

  /* ────────── Homepage layout ──────────
     The page has three regions:
       - .home-top-featured  : top 2 featured cards (always visible)
       - .home-rail-featured : featured #3+ (desktop only — right rail)
       - .home-main-feed     : regulars + dup'd rest-featured, Masonry-laid
     Three breakpoints:
       - desktop ≥1100px: 60/40 grid, main on the left, featured regions on
         the right rail (top-featured above, rail-featured below).
       - tablet  700–1099px: stacked; top-featured renders as a 2-col row
         above the 2-col main feed. Rail hidden.
       - mobile  <700px: single column; top-featured stacked at top. Rail
         hidden. On tablet+mobile, featured #3+ appears inside the main feed
         as regular-styled cards (via .feed-dup-featured — hidden on desktop
         so cards don't double up).                                        */
  .home-layout {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
    grid-template-areas: "top" "main" "rail";
  }
  .home-top-featured  { grid-area: top;  display: flex; flex-direction: column; gap: 1rem; }
  .home-rail-featured { grid-area: rail; display: flex; flex-direction: column; gap: 1rem; }
  .home-main-feed     { grid-area: main; margin: 0 -0.5rem; }

  /* Main-feed Masonry columns: 1 below 480px, 2 everywhere above.
     Much simpler than the old 1/2/3/4-tier system because the outer layout
     (not the card count) now handles viewport adaptation. */
  .home-main-feed .grid-sizer,
  .home-main-feed .card { width: calc(100% - 1rem); margin: 0.5rem; box-sizing: border-box; }
  .home-main-feed .grid-sizer { height: 0; padding: 0; margin: 0.5rem; visibility: hidden; }
  @media (min-width: 480px) {
    .home-main-feed .grid-sizer,
    .home-main-feed .card { width: calc(50% - 1rem); }
  }

  /* Tablet: rail hidden, top-featured becomes a 2-col row. */
  @media (min-width: 700px) and (max-width: 1099px) {
    .home-top-featured { flex-direction: row; }
    .home-top-featured > .card { flex: 1 1 0; min-width: 0; }
    .home-rail-featured { display: none; }
  }

  /* Mobile: rail hidden (top-featured stays as flex column, 2 cards stacked) */
  @media (max-width: 699px) {
    .home-rail-featured { display: none; }
  }

  /* Desktop: 60/40 split, featured regions live in the right rail.
     main spans both grid rows so the feed uses the full height of the right
     column regardless of which side is taller. The .feed-dup-featured hide
     removes the duplicates from Masonry on desktop — they only exist in the
     DOM so tablet/mobile can show featured #3+ inline as regular cards. */
  @media (min-width: 1100px) {
    .home-layout {
      grid-template-columns: 6fr 4fr;
      grid-template-areas:
        "main top"
        "main rail";
      grid-template-rows: auto 1fr;
    }
    .home-main-feed .feed-dup-featured { display: none !important; }
  }

  /* ────────── Featured card display treatment ──────────
     Same card template as regulars, but when a card lives inside a featured
     region it renders with a larger headline, no emoji, and image-only
     framing. Differentiation is purely visual — width is dictated by the
     enclosing region, not by the card itself, which is why Masonry no
     longer has to deal with mixed widths. */
  .card-featured-display .card-emoji { display: none; }
  .card-featured-display .card-title {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.3;
  }
  @media (min-width: 640px) {
    .card-featured-display .card-title { font-size: 1.25rem; }
  }

  .card {
    position: relative;
    border-radius: 1rem; padding: 1.1rem; border: 2px solid transparent;
    text-decoration: none; display: flex; flex-direction: column; gap: 0.4rem;
    transition: transform 0.15s, box-shadow 0.15s; -webkit-tap-highlight-color: transparent;
  }
  @media (min-width: 640px) { .card { padding: 1.25rem; gap: 0.5rem; } }
  @media (hover: hover) { .card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.10); } }

  /* Card click target. An invisible <a> overlaid on the whole card via
     inset:0 sends the user to the source article. Sitting at z-index:1,
     it captures clicks on the image + title + summary + source + date —
     everything except the explicit Positron-permalink icon which is
     pulled to z-index:2. Avoids nested <a> tags (invalid HTML) while
     still letting the entire card act as a single link to the source. */
  .card-link {
    position: absolute; inset: 0;
    z-index: 1;
    border-radius: inherit;
    text-decoration: none;
  }
  .card-link:focus-visible {
    outline: 2px solid currentColor; outline-offset: 2px;
  }

  .card-meta-right { display: inline-flex; align-items: center; gap: 0.4rem; }
  .card-permalink {
    position: relative; z-index: 2;
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px;
    color: inherit;
    opacity: 0.4;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .card-permalink:hover { opacity: 1; }
  .card-permalink svg { width: 14px; height: 14px; display: block; }

  /* Card thumbnail image — bleeds to card edges, rounded top corners */
  .card-img {
    width: calc(100% + 2.2rem); margin: -1.1rem -1.1rem 0.5rem;
    border-radius: 0.85rem 0.85rem 0 0;
    aspect-ratio: 16/9; object-fit: cover; display: block;
  }
  @media (min-width: 640px) {
    .card-img { width: calc(100% + 2.5rem); margin: -1.25rem -1.25rem 0.5rem; }
  }

  .card-emoji { font-size: 1.5rem; }
  .card-tags { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .card-tag {
    font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.04em; opacity: 0.7;
    color: inherit; text-decoration: none;
    position: relative; z-index: 2;
  }
  .card-tag:hover { opacity: 1; text-decoration: underline; }
  .card-tag-sep { font-size: 0.65rem; opacity: 0.5; }
  .card-title { font-size: 0.95rem; font-weight: 600; line-height: 1.4; }
  .card-summary { font-size: 0.825rem; line-height: 1.55; opacity: 0.85; }
  .card-meta { font-size: 0.7rem; margin-top: auto; padding-top: 0.5rem; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.25rem; }
  /* Mute source/date text without dimming the .card-permalink icon
     (otherwise parent opacity stacks with .card-permalink's own 0.4 and
     the icon becomes invisible on Classic — Mono/Mondrian dodge this
     via their own .card-meta { opacity: 1 } override in themes.css). */
  .card-meta > span:not(.card-meta-right),
  .card-meta-right > span { opacity: 0.6; }
  .empty { color: #b45309; font-size: 0.9rem; }
  .no-match { display: none; color: #b45309; font-size: 0.9rem; margin-top: 1rem; }
  .no-match.visible { display: block; }

  .card-yellow  { background:#fef9c3; border-color:#fde047; color:#713f12; }
  .card-orange  { background:#ffedd5; border-color:#fb923c; color:#7c2d12; }
  .card-rose    { background:#ffe4e6; border-color:#fb7185; color:#881337; }
  .card-purple  { background:#f3e8ff; border-color:#c084fc; color:#581c87; }
  .card-blue    { background:#dbeafe; border-color:#60a5fa; color:#1e3a5f; }
  .card-cyan    { background:#cffafe; border-color:#22d3ee; color:#164e63; }
  .card-teal    { background:#ccfbf1; border-color:#2dd4bf; color:#134e4a; }
  .card-green   { background:#dcfce7; border-color:#4ade80; color:#14532d; }
  .card-lime    { background:#ecfccb; border-color:#a3e635; color:#365314; }
  .card-pink    { background:#fce7f3; border-color:#f472b6; color:#831843; }

  /* ────────── Mobile (<700px) compact layout ──────────
     The goal on phones is that several articles are visible as soon as
     the page opens, rather than one full card filling the viewport.
     Two layouts kick in together:

       - Top-featured becomes a 2-col row of hero TILES: image on top,
         title below, nothing else. Both featured #1 and featured #2
         get this treatment — the "lead story" idea is preserved by
         visual prominence (larger image, featured font weight), but
         both fit above the fold.

       - Everything else becomes compact ROWS: 80×80 thumbnail on the
         left, title on the right. The main feed is also forced to 1
         column so rows are full-width and easy to tap.

     Mobile also swaps the active card-link: every card links to the
     Positron intermediate page (post.url) rather than jumping straight
     to the external source. Rationale: tapping an external link from a
     standalone PWA drops the user out of the app shell, and on mobile
     the summary isn't shown inline anyway — so the intermediate page
     is the natural next step. Desktop keeps jump-to-source because
     the summary is already inline on the homepage. */
  .card-link-mobile { display: none; }

  @media (max-width: 699px) {
    /* ─── Top-featured: 2-col hero tiles ─── */
    .home-top-featured {
      flex-direction: row;
      gap: 0.5rem;
    }
    .home-top-featured > .card {
      flex: 1 1 0;
      min-width: 0;
      padding: 0.5rem;
      gap: 0.3rem;
    }
    .home-top-featured .card-img {
      width: calc(100% + 1rem);
      margin: -0.5rem -0.5rem 0.25rem;
      aspect-ratio: 16 / 9;
      border-radius: 0.5rem 0.5rem 0 0;
    }
    .home-top-featured .card-emoji,
    .home-top-featured .card-tags,
    .home-top-featured .card-summary,
    .home-top-featured .card-meta {
      display: none;
    }
    .home-top-featured .card-title {
      font-size: 0.85rem;
      line-height: 1.3;
      font-weight: 700;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* ─── Main feed + rest-featured dupes: compact rows ─── */
    .card.card-mobile-compact {
      flex-direction: row;
      gap: 0.75rem;
      padding: 0.75rem;
      align-items: center;
    }
    .card.card-mobile-compact .card-img {
      width: 80px;
      height: 80px;
      aspect-ratio: 1 / 1;
      margin: 0;
      border-radius: 0.5rem;
      flex-shrink: 0;
      object-fit: cover;
    }
    .card.card-mobile-compact .card-emoji,
    .card.card-mobile-compact .card-tags,
    .card.card-mobile-compact .card-summary,
    .card.card-mobile-compact .card-meta {
      display: none;
    }
    .card.card-mobile-compact .card-title {
      font-size: 0.95rem;
      line-height: 1.35;
      font-weight: 600;
      flex: 1;
      min-width: 0;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* Force 1-col main feed on phones so compact rows are full-width and
       comfortable to tap. Overrides the 480px+ 2-col Masonry rule. */
    .home-main-feed .grid-sizer,
    .home-main-feed .card { width: calc(100% - 1rem); }

    /* Swap card-link routing: in-PWA link active, external link disabled. */
    .card-link-desktop { display: none; }
    .card-link-mobile { display: block; }
  }
</style>

<div class="page-header">
  <h1>
    <span class="t-en">Positive news, every day ✨</span>
    <span class="t-nl" style="display:none">Positief nieuws, elke dag ✨</span>
    <span class="t-fr" style="display:none">Actualités positives, chaque jour ✨</span>
  </h1>
  <p>
    <span class="t-en">A curated selection of good things happening in the world.</span>
    <span class="t-nl" style="display:none">Een gecureerde selectie van goede dingen in de wereld.</span>
    <span class="t-fr" style="display:none">Une sélection soignée de bonnes nouvelles dans le monde.</span>
  </p>
</div>

{% if collections.posts.length == 0 %}
  <p class="empty">No posts yet - check back soon!</p>
{% else %}

  {# How many posts appear in the main feed. Top 2 featured always show, so
     the main feed gets ~58 items. Older articles live in the archive. #}
  {% set mainFeedLimit = 58 %}
  {% set mainFeedPosts = collections.homeMainFeedItems | limit(mainFeedLimit) %}

  {# Tags shown in the filter picker: union across all three regions on the
     current page (top-featured + rail-featured + main-feed shown items). #}
  {% set seenTags = [] %}
  {% for post in (collections.homeTopFeatured.concat(collections.homeRestFeatured).concat(mainFeedPosts)) %}
    {% if post.data.tags and post.data.tags.length > 0 %}
      {% for tag in post.data.tags %}
        {% if tag and tag != "" and tag not in seenTags %}
          {% set seenTags = (seenTags.concat([tag])) %}
        {% endif %}
      {% endfor %}
    {% elif post.data.topic and post.data.topic != "" and post.data.topic not in seenTags %}
      {% set seenTags = (seenTags.concat([post.data.topic])) %}
    {% endif %}
  {% endfor %}

  {# ────────── Card render macro ──────────
     Single definition reused across all three homepage regions. The
     extraClass argument injects a region-specific modifier:
       - 'card-featured-display' : larger headline + no emoji (featured look)
       - 'feed-dup-featured'     : main-feed duplicate of a rest-featured
                                    post, hidden on desktop via CSS
       - ''                       : regular card                          #}
  {% macro card(post, extraClass) %}
    {% if post.data.tags and post.data.tags.length > 0 %}
      {% set cardTags = post.data.tags %}
    {% elif post.data.topic %}
      {% set cardTags = [post.data.topic] %}
    {% else %}
      {% set cardTags = [] %}
    {% endif %}
    {% set firstTag = cardTags[0] if cardTags.length > 0 else "" %}
    <article
      class="card card-{{ firstTag | topicColor }}{% if extraClass %} {{ extraClass }}{% endif %}"
      data-tags="{{ cardTags | join(',') }}"
      data-date="{{ post.date | dateMonthKey }}"
      data-sitedate="{{ post.date | dateIso }}"
      data-fulldate="{% if post.data.source_pub_date %}{{ post.data.source_pub_date }}{% else %}{{ post.date | dateIso }}{% endif %}"
    >
      <a class="card-link card-link-desktop"
         href="{{ post.data.source_url }}"
         target="_blank"
         rel="noopener noreferrer"
         aria-label="{{ post.data.title | striptags | replace('\"','') }} — read at {{ post.data.source_name }} (opens in a new tab)"></a>
      <a class="card-link card-link-mobile"
         href="{{ post.url | url }}"
         aria-label="{{ post.data.title | striptags | replace('\"','') }}"></a>

      {% if post.data.image_url %}<img class="card-img" src="{{ post.data.image_url }}" alt="{{ post.data.title | striptags | replace('\"','') }}" loading="lazy" onerror="this.style.display='none'">{% endif %}
      <div class="card-emoji">{{ post.data.emoji }}</div>
      <div class="card-tags">
        {% for tag in cardTags %}<a class="card-tag" href="/tags/{{ tag | slugify }}/">{{ tag }}</a>{% if not loop.last %} <span class="card-tag-sep" aria-hidden="true">·</span> {% endif %}{% endfor %}
      </div>
      <div class="card-title">
        <span class="t-en">{{ post.data.title }}</span>
        <span class="t-nl" style="display:none">{{ post.data.title_nl if post.data.title_nl else post.data.title }}</span>
        <span class="t-fr" style="display:none">{{ post.data.title_fr if post.data.title_fr else post.data.title }}</span>
      </div>
      {% if post.data.summary %}
      <div class="card-summary">
        <span class="t-en">{{ post.data.summary }}</span>
        <span class="t-nl" style="display:none">{{ post.data.summary_nl if post.data.summary_nl else post.data.summary }}</span>
        <span class="t-fr" style="display:none">{{ post.data.summary_fr if post.data.summary_fr else post.data.summary }}</span>
      </div>
      {% endif %}
      <div class="card-meta">
        <span>{{ post.data.source_name }}</span>
        <span class="card-meta-right">
          <span>{{ post.date | dateTimeShort }}</span>
          <a class="card-permalink"
             href="{{ post.url | url }}"
             title="Open on Positron Today"
             aria-label="Open on Positron Today">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" aria-hidden="true">
              <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="currentColor" stroke-width="8"/>
              <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="currentColor" stroke-width="8" transform="rotate(60 50 50)"/>
              <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="currentColor" stroke-width="8" transform="rotate(120 50 50)"/>
              <circle cx="50" cy="50" r="12" fill="currentColor"/>
            </svg>
          </a>
        </span>
      </div>
    </article>
  {% endmacro %}

  <div class="filter-bar">
    {% if seenTags.length > 0 %}
    <div class="tag-picker" id="tag-picker">
      <button class="tag-picker-btn" id="tag-picker-btn" onclick="toggleTagPicker(event)">
        <span id="tag-picker-label">
          <span class="t-en">Topics</span>
          <span class="t-nl" style="display:none">Onderwerpen</span>
          <span class="t-fr" style="display:none">Sujets</span>
          <span id="tag-count-suffix"></span>
        </span> ▾
      </button>
      <div class="tag-picker-panel" id="tag-picker-panel">
        <div class="tag-chips">
          <button class="tag-chip tag-chip-all selected" data-tag="all" onclick="toggleTag('all')">
            <span class="t-en">All</span>
            <span class="t-nl" style="display:none">Alle</span>
            <span class="t-fr" style="display:none">Tout</span>
          </button>
          {% for tag in seenTags %}
          <button class="tag-chip tchip-{{ tag | topicColor }}" data-tag="{{ tag }}" onclick="toggleTag('{{ tag }}')">{{ tag }}</button>
          {% endfor %}
        </div>
      </div>
    </div>
    {% endif %}

    <select class="date-range-select" id="date-range-select" onchange="filterDateRange(this.value)">
      <option value="all"   data-en="All time"      data-nl="Alle tijd"         data-fr="Toute période">All time</option>
      <option value="today" data-en="Today"          data-nl="Vandaag"           data-fr="Aujourd'hui">Today</option>
      <option value="7d"    data-en="Last 7 days"   data-nl="Laatste 7 dagen"   data-fr="7 derniers jours">Last 7 days</option>
      <option value="30d"   data-en="Last 30 days"  data-nl="Laatste 30 dagen"  data-fr="30 derniers jours">Last 30 days</option>
      <option value="3m"    data-en="Last 3 months" data-nl="Laatste 3 maanden" data-fr="3 derniers mois">Last 3 months</option>
      <option value="6m"    data-en="Last 6 months" data-nl="Laatste 6 maanden" data-fr="6 derniers mois">Last 6 months</option>
      <option value="year"  data-en="This year"     data-nl="Dit jaar"          data-fr="Cette année">This year</option>
    </select>

    <button class="filter-clear" id="filter-clear" onclick="clearAllFilters()" style="display:none">
      <span class="t-en">Clear ✕</span>
      <span class="t-nl" style="display:none">Wis ✕</span>
      <span class="t-fr" style="display:none">Effacer ✕</span>
    </button>
  </div>

  <div class="home-layout">
    <section class="home-top-featured">
      {% for post in collections.homeTopFeatured %}
        {{ card(post, 'card-featured-display') }}
      {% endfor %}
    </section>

    <section class="home-rail-featured">
      {% for post in collections.homeRestFeatured %}
        {{ card(post, 'card-featured-display') }}
      {% endfor %}
    </section>

    <section class="home-main-feed" id="card-grid">
      <div class="grid-sizer"></div>
      {% for post in mainFeedPosts %}
        {# Rest-featured duplicates render with regular styling but get the
           .feed-dup-featured class so CSS hides them on desktop (where the
           same posts are shown in the rail with featured styling). #}
        {% if post.data.featured %}
          {{ card(post, 'feed-dup-featured card-mobile-compact') }}
        {% else %}
          {{ card(post, 'card-mobile-compact') }}
        {% endif %}
      {% endfor %}
    </section>
  </div>
  <p class="no-match" id="no-match">
    <span class="t-en">No articles for this filter yet.</span>
    <span class="t-nl" style="display:none">Geen artikelen gevonden voor dit filter.</span>
    <span class="t-fr" style="display:none">Aucun article trouvé pour ce filtre.</span>
  </p>

  {% if collections.posts.length > 60 %}
  <p style="text-align:center; margin-top:1.75rem; font-size:0.875rem; color:#b45309;">
    <a href="{{ '/archive/' | url }}" style="color:#b45309; font-weight:600; text-decoration:none; border-bottom: 1.5px solid #fde68a; padding-bottom:1px;">
      <span class="t-en">Browse the full archive ({{ collections.posts.length }} articles) →</span>
      <span class="t-nl" style="display:none">Volledig archief bekijken ({{ collections.posts.length }} artikelen) →</span>
      <span class="t-fr" style="display:none">Parcourir les archives complètes ({{ collections.posts.length }} articles) →</span>
    </a>
  </p>
  {% endif %}

{% endif %}

<script>
  // ── Translate date-range <select> options on language switch ─────────────
  function translateDateSelect(lang) {
    var sel = document.getElementById('date-range-select');
    if (!sel) return;
    Array.from(sel.options).forEach(function(opt) {
      var label = opt.getAttribute('data-' + lang) || opt.getAttribute('data-en');
      if (label) opt.textContent = label;
    });
  }

  // Override setLang so language switches also retranslate the select
  var _baseSLang = window.setLang;
  window.setLang = function(lang, btn) {
    _baseSLang(lang, btn);
    translateDateSelect(lang);
  };

  // ── Tag multi-select + date-range filter ─────────────────────────────────
  var activeTags = new Set(); // empty = show all
  var activeDateRange = 'all';

  // Returns a YYYY-MM-DD cutoff string, or null for "all time"
  // Returns today's date as "YYYY-MM-DD" in local time (avoids UTC timezone shift)
  function localToday() {
    var d = new Date();
    var mm = String(d.getMonth() + 1).padStart(2, '0');
    var dd = String(d.getDate()).padStart(2, '0');
    return d.getFullYear() + '-' + mm + '-' + dd;
  }

  function dateCutoff(range) {
    if (range === 'all') return null;
    if (range === 'today') return localToday();
    var d = new Date();
    if (range === '7d')        { d.setDate(d.getDate() - 7);      }
    else if (range === '30d')  { d.setDate(d.getDate() - 30);     }
    else if (range === '3m')   { d.setMonth(d.getMonth() - 3);    }
    else if (range === '6m')   { d.setMonth(d.getMonth() - 6);    }
    else if (range === 'year') { d = new Date(d.getFullYear(), 0, 1); }
    return d.toISOString().slice(0, 10);
  }

  function applyFilters() {
    // Filter spans all three regions (top-featured, rail-featured, main-feed).
    // Rest-featured duplicates live in the main feed tagged .feed-dup-featured
    // — they're hidden by CSS on desktop regardless of filter state, so they
    // don't count toward the "visible" total (otherwise a desktop user with a
    // filter active could see an empty layout but get no "no match" message).
    var cards = document.querySelectorAll('.home-layout .card');
    var visible = 0;
    var cutoff = dateCutoff(activeDateRange);
    cards.forEach(function(card) {
      var cardTags = (card.dataset.tags || '').split(',').map(function(t) { return t.trim(); }).filter(Boolean);
      var tagMatch  = activeTags.size === 0 || cardTags.some(function(t) { return activeTags.has(t); });
      // "Today" compares against when Positron published it (sitedate), not the source's original date
      var cardDate  = activeDateRange === 'today' ? (card.dataset.sitedate || '') : (card.dataset.fulldate || '');
      var dateMatch = !cutoff || cardDate >= cutoff;
      var show = tagMatch && dateMatch;
      card.style.display = show ? '' : 'none';
      if (show && !card.classList.contains('feed-dup-featured')) visible++;
    });
    var noMatch = document.getElementById('no-match');
    if (noMatch) noMatch.classList.toggle('visible', visible === 0);
    updateFilterUI();
  }

  function updateFilterUI() {
    var btn   = document.getElementById('tag-picker-btn');
    var clear = document.getElementById('filter-clear');
    var allChip = document.querySelector('.tag-chip-all');
    var rangeEl = document.getElementById('date-range-select');
    if (!btn) return;

    // Tag picker button state
    if (activeTags.size === 0) {
      btn.classList.remove('has-selection');
      if (allChip) allChip.classList.add('selected');
    } else {
      btn.classList.add('has-selection');
      if (allChip) allChip.classList.remove('selected');
    }
    document.querySelectorAll('.tag-chip:not(.tag-chip-all)').forEach(function(chip) {
      chip.classList.toggle('selected', activeTags.has(chip.dataset.tag));
    });
    var countEl = document.getElementById('tag-count-suffix');
    if (countEl) countEl.textContent = activeTags.size > 0 ? ' (' + activeTags.size + ')' : '';

    // Date-range select highlight
    if (rangeEl) rangeEl.classList.toggle('has-selection', activeDateRange !== 'all');

    // Clear button
    var hasFilter = activeTags.size > 0 || activeDateRange !== 'all';
    if (clear) clear.style.display = hasFilter ? '' : 'none';
  }

  function toggleTag(tag) {
    if (tag === 'all') { activeTags.clear(); }
    else { if (activeTags.has(tag)) activeTags.delete(tag); else activeTags.add(tag); }
    localStorage.setItem('positron-today-tags', JSON.stringify([...activeTags]));
    applyFilters();
  }

  function toggleTagPicker(e) {
    e.stopPropagation();
    var panel = document.getElementById('tag-picker-panel');
    if (panel) panel.classList.toggle('open');
  }

  document.addEventListener('click', function(e) {
    var picker = document.getElementById('tag-picker');
    var panel  = document.getElementById('tag-picker-panel');
    if (panel && picker && !picker.contains(e.target)) panel.classList.remove('open');
  });

  function filterDateRange(val) {
    activeDateRange = val;
    localStorage.setItem('positron-today-daterange', val);
    applyFilters();
  }

  function clearAllFilters() {
    activeTags.clear();
    activeDateRange = 'all';
    localStorage.removeItem('positron-today-tags');
    localStorage.removeItem('positron-today-daterange');
    var sel = document.getElementById('date-range-select');
    if (sel) sel.value = 'all';
    applyFilters();
  }


  // Translate select to whatever language is already active
  translateDateSelect(document.documentElement.getAttribute('data-lang') || 'en');

  // Restore saved filters
  (function() {
    try {
      var savedTags = JSON.parse(localStorage.getItem('positron-today-tags') || '[]');
      savedTags.forEach(function(t) { activeTags.add(t); });
    } catch(e) {}
    var savedRange = localStorage.getItem('positron-today-daterange');
    if (savedRange && savedRange !== 'all') {
      activeDateRange = savedRange;
      var sel = document.getElementById('date-range-select');
      if (sel) sel.value = savedRange;
    }
    if (activeTags.size > 0 || activeDateRange !== 'all') applyFilters();
    else updateFilterUI();
  })();
</script>

<script src="https://unpkg.com/masonry-layout@4/dist/masonry.pkgd.min.js"></script>
<script src="https://unpkg.com/imagesloaded@5/imagesloaded.pkgd.min.js"></script>
<script>
  // Initialize Masonry on the main feed only. The top-featured and
  // rail-featured regions are simple flex stacks — they don't need Masonry
  // because every card in them is the same width.
  var grid = document.getElementById('card-grid');
  if (grid) {
    var msnry = new Masonry(grid, {
      itemSelector: '.card',
      columnWidth: '.grid-sizer',
      percentPosition: true,
      transitionDuration: '0.2s'
    });
    // Re-layout after all images load
    imagesLoaded(grid, function() {
      msnry.layout();
      trimRailToFeed();
    });
    // Re-layout after filters hide/show cards
    var _baseApply = window.applyFilters;
    window.applyFilters = function() {
      _baseApply();
      setTimeout(function() {
        msnry.layout();
        trimRailToFeed();
      }, 50);
    };
    // Expose for manual re-layout if needed
    window.msnry = msnry;
  }

  // Trim the desktop featured rail so it ends at roughly the same vertical
  // position as the main feed — prevents a very tall rail leaving a big
  // white-space hole at the bottom of the left column when there are many
  // featured articles but few regulars. Only active on desktop (≥1100px);
  // tablet/mobile hide the rail entirely via CSS.
  function trimRailToFeed() {
    var rail = document.querySelector('.home-rail-featured');
    var feed = document.getElementById('card-grid');
    if (!rail || !feed) return;

    var cards = rail.querySelectorAll('.card');
    // Always reset before re-measuring so resize from desktop → tablet → desktop
    // doesn't leave stale hidden cards.
    cards.forEach(function(c) { c.style.display = ''; });

    if (window.innerWidth < 1100) return;

    // Hide any rail card that would extend past the main feed's bottom —
    // check the card's *bottom*, not its top, so the rail never pokes below
    // the feed (user preference: both columns end roughly together). Each
    // display:none triggers a reflow, so the next card's measured position
    // reflects the new layout — the loop compounds correctly.
    var feedBottom = feed.getBoundingClientRect().bottom + window.scrollY;
    cards.forEach(function(card) {
      var bottom = card.getBoundingClientRect().bottom + window.scrollY;
      if (bottom > feedBottom + 8) card.style.display = 'none';
    });
  }

  // Re-run trim on resize (debounced). Keeps the rail in step when the user
  // drags the window across the 1100px breakpoint or simply changes width.
  var _trimTimer = null;
  window.addEventListener('resize', function() {
    clearTimeout(_trimTimer);
    _trimTimer = setTimeout(trimRailToFeed, 120);
  });
</script>
