---
layout: base.njk
title: Home
---

<style>
  .page-header { margin-bottom: 1.25rem; }
  .page-header h1 { font-size: clamp(1.35rem, 5vw, 1.75rem); font-weight: 700; color: #78350f; margin-bottom: 0.25rem; }
  .page-header p { font-size: 0.875rem; color: #b45309; }

  .lang-tabs { display: flex; gap: 0.4rem; margin-bottom: 1rem; flex-wrap: wrap; }
  .lang-tab {
    padding: 0.4rem 0.9rem; border-radius: 99px; font-size: 0.8rem;
    font-weight: 600; cursor: pointer; border: none;
    background: #fef3c7; color: #92400e; transition: background 0.15s;
    -webkit-tap-highlight-color: transparent; min-height: 36px;
  }
  .lang-tab.active { background: #facc15; color: #78350f; }

  .topic-bar, .month-bar { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.25rem; align-items: center; }
  .topic-bar-label, .month-bar-label { font-size: 0.7rem; font-weight: 600; color: #b45309; text-transform: uppercase; letter-spacing: 0.05em; width: 100%; }
  .topic-btn, .month-btn {
    padding: 0.4rem 0.9rem; border-radius: 99px; font-size: 0.8rem;
    font-weight: 600; cursor: pointer; border: 2px solid transparent;
    transition: all 0.15s; white-space: nowrap;
    -webkit-tap-highlight-color: transparent; min-height: 36px;
  }
  .topic-btn.active { border-color: currentColor; box-shadow: 0 0 0 2px rgba(0,0,0,0.08); }
  .month-btn { background: #fef3c7; color: #92400e; }
  .month-btn.active { background: #f59e0b; border-color: #d97706; color: #78350f; box-shadow: 0 0 0 2px rgba(0,0,0,0.08); }
  @media (min-width: 480px) { .topic-bar-label, .month-bar-label { width: auto; } }

  .tbtn-yellow { background:#fef9c3; color:#713f12; } .tbtn-yellow.active { background:#fde047; }
  .tbtn-orange { background:#ffedd5; color:#7c2d12; } .tbtn-orange.active { background:#fb923c; }
  .tbtn-rose   { background:#ffe4e6; color:#881337; } .tbtn-rose.active   { background:#fb7185; }
  .tbtn-purple { background:#f3e8ff; color:#581c87; } .tbtn-purple.active { background:#c084fc; }
  .tbtn-blue   { background:#dbeafe; color:#1e3a5f; } .tbtn-blue.active   { background:#60a5fa; }
  .tbtn-cyan   { background:#cffafe; color:#164e63; } .tbtn-cyan.active   { background:#22d3ee; }
  .tbtn-teal   { background:#ccfbf1; color:#134e4a; } .tbtn-teal.active   { background:#2dd4bf; }
  .tbtn-green  { background:#dcfce7; color:#14532d; } .tbtn-green.active  { background:#4ade80; }
  .tbtn-lime   { background:#ecfccb; color:#365314; } .tbtn-lime.active   { background:#a3e635; }
  .tbtn-pink   { background:#fce7f3; color:#831843; } .tbtn-pink.active   { background:#f472b6; }

  /* Masonry column layout — cards vary in height naturally */
  .card-grid { columns: 1; column-gap: 1rem; }
  @media (min-width: 480px) { .card-grid { columns: 2; } }
  @media (min-width: 700px) { .card-grid { columns: 3; column-gap: 1.25rem; } }

  .card {
    break-inside: avoid;
    margin-bottom: 1rem;
    border-radius: 1rem; padding: 1.1rem; border: 2px solid transparent;
    text-decoration: none; display: flex; flex-direction: column; gap: 0.4rem;
    transition: transform 0.15s, box-shadow 0.15s; -webkit-tap-highlight-color: transparent;
  }
  @media (min-width: 640px) { .card { padding: 1.25rem; gap: 0.5rem; margin-bottom: 1.25rem; } }
  @media (hover: hover) { .card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.10); } }

  .card-emoji { font-size: 1.5rem; }
  .card-tags { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .card-tag { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.04em; opacity: 0.7; }
  .card-title { font-size: 0.95rem; font-weight: 600; line-height: 1.4; }
  .card-summary { font-size: 0.825rem; line-height: 1.55; opacity: 0.85; }
  .card-meta { font-size: 0.7rem; opacity: 0.6; margin-top: auto; padding-top: 0.5rem; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.25rem; }
  .empty { color: #b45309; font-size: 0.9rem; }
  .no-match { display: none; color: #b45309; font-size: 0.9rem; margin-top: 1rem; }
  .no-match.visible { display: block; }

  .card-yellow  { background:#fef9c3; border-color:#fde047; color:#713f12; }
  .card-orange  { background:#ffedd5; border-color:#fb923c; color:#7c2d12; }
  .card-rose    { background:#ffe4e6; border-color:#fb7185; color:#881337; }
  .card-purple  { background:#f3e8ff; border-color:#c084fc; color:#581c87; }
  .card-blue    { background:#dbeafe; border-color:#60a5fa; color:#1e3a5f; }
  .card-cyan    { background:#cffafe; border-color:#22d3ee; color:#164e63; }
  .card-teal    { background:#ccfbf1; border-color:#2dd4bf; color:#134e4a; }
  .card-green   { background:#dcfce7; border-color:#4ade80; color:#14532d; }
  .card-lime    { background:#ecfccb; border-color:#a3e635; color:#365314; }
  .card-pink    { background:#fce7f3; border-color:#f472b6; color:#831843; }
</style>

<div class="page-header">
  <h1>Positive news, every day ✨</h1>
  <p>A curated selection of good things happening in the world.</p>
</div>

<div class="lang-tabs">
  <button class="lang-tab active" onclick="setLang('en', this)">EN</button>
  <button class="lang-tab" onclick="setLang('nl', this)">NL</button>
  <button class="lang-tab" onclick="setLang('fr', this)">FR</button>
</div>

{% if collections.posts.length == 0 %}
  <p class="empty">No posts yet - check back soon!</p>
{% else %}

  {# Collect unique tags across all posts #}
  {% set seenTags = [] %}
  {% for post in collections.posts %}
    {% if post.data.tags and post.data.tags.length > 0 %}
      {% for tag in post.data.tags %}
        {% if tag and tag != "" and tag not in seenTags %}
          {% set seenTags = (seenTags.concat([tag])) %}
        {% endif %}
      {% endfor %}
    {% elif post.data.topic and post.data.topic != "" and post.data.topic not in seenTags %}
      {% set seenTags = (seenTags.concat([post.data.topic])) %}
    {% endif %}
  {% endfor %}

  {# Collect unique months (most-recent first, since posts are sorted that way) #}
  {% set seenMonths = [] %}
  {% for post in collections.posts %}
    {% set mk = post.date | dateMonthKey %}
    {% if mk not in seenMonths %}
      {% set seenMonths = seenMonths.concat([mk]) %}
    {% endif %}
  {% endfor %}

  {% if seenTags.length > 0 %}
  <div class="topic-bar" id="topic-bar">
    <span class="topic-bar-label">Tag</span>
    <button class="topic-btn tbtn-yellow active" data-topic="all" onclick="filterTopic('all', this)">All</button>
    {% for tag in seenTags %}
    <button class="topic-btn tbtn-{{ tag | topicColor }}" data-topic="{{ tag }}" onclick="filterTopic('{{ tag }}', this)">{{ tag }}</button>
    {% endfor %}
  </div>
  {% endif %}

  {% if seenMonths.length > 1 %}
  <div class="month-bar" id="month-bar">
    <span class="month-bar-label">Month</span>
    <button class="month-btn active" data-month="all" onclick="filterMonth('all', this)">All</button>
    {% for mk in seenMonths %}
    <button class="month-btn" data-month="{{ mk }}" onclick="filterMonth('{{ mk }}', this)">{{ mk | dateMonthLabel }}</button>
    {% endfor %}
  </div>
  {% endif %}

  <div class="card-grid" id="card-grid">
    {% for post in collections.posts %}
      {# Resolve tags: use tags[] if present, fall back to topic string #}
      {% if post.data.tags and post.data.tags.length > 0 %}
        {% set cardTags = post.data.tags %}
      {% elif post.data.topic %}
        {% set cardTags = [post.data.topic] %}
      {% else %}
        {% set cardTags = [] %}
      {% endif %}
      {% set firstTag = cardTags[0] if cardTags.length > 0 else "" %}
    <a
      href="{{ post.url | url }}"
      class="card card-{{ firstTag | topicColor }}"
      data-tags="{{ cardTags | join(',') }}"
      data-date="{{ post.date | dateMonthKey }}"
    >
      <div class="card-emoji">{{ post.data.emoji }}</div>
      <div class="card-tags">
        {% for tag in cardTags %}<span class="card-tag">{{ tag }}{% if not loop.last %} · {% endif %}</span>{% endfor %}
      </div>
      <div class="card-title">
        <span class="t-en">{{ post.data.title }}</span>
        <span class="t-nl" style="display:none">{{ post.data.title_nl if post.data.title_nl else post.data.title }}</span>
        <span class="t-fr" style="display:none">{{ post.data.title_fr if post.data.title_fr else post.data.title }}</span>
      </div>
      {% if post.data.summary %}
      <div class="card-summary">
        <span class="t-en">{{ post.data.summary }}</span>
        <span class="t-nl" style="display:none">{{ post.data.summary_nl if post.data.summary_nl else post.data.summary }}</span>
        <span class="t-fr" style="display:none">{{ post.data.summary_fr if post.data.summary_fr else post.data.summary }}</span>
      </div>
      {% endif %}
      <div class="card-meta">
        <span>{{ post.data.source_name }}</span>
        <span>{{ post.date | dateDisplay }}</span>
      </div>
    </a>
    {% endfor %}
  </div>
  <p class="no-match" id="no-match">No articles for this tag yet.</p>

{% endif %}

<script>
  const LANGS = ['en', 'nl', 'fr'];
  function setLang(lang, btn) {
    LANGS.forEach(function(l) {
      document.querySelectorAll('.t-' + l).forEach(function(el) { el.style.display = l === lang ? '' : 'none'; });
    });
    document.querySelectorAll('.lang-tab').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    localStorage.setItem('positiviteiten-lang', lang);
  }
  (function() {
    var saved = localStorage.getItem('positiviteiten-lang');
    if (saved && saved !== 'en') {
      var btn = document.querySelector('.lang-tab[onclick*="' + saved + '"]');
      if (btn) setLang(saved, btn);
    }
  })();

  var activeTag = 'all';
  var activeMonth = 'all';

  function applyFilters() {
    var cards = document.querySelectorAll('#card-grid .card');
    var visible = 0;
    cards.forEach(function(card) {
      var cardTags = (card.dataset.tags || '').split(',').map(function(t) { return t.trim(); }).filter(Boolean);
      var tagMatch = activeTag === 'all' || cardTags.includes(activeTag);
      var monthMatch = activeMonth === 'all' || card.dataset.date === activeMonth;
      var show = tagMatch && monthMatch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    var noMatch = document.getElementById('no-match');
    if (noMatch) noMatch.classList.toggle('visible', visible === 0);
  }

  function filterTopic(topic, btn) {
    document.querySelectorAll('.topic-btn').forEach(function(b) { b.classList.remove('active'); });
    if (btn) btn.classList.add('active');
    activeTag = topic;
    localStorage.setItem('positiviteiten-topic', topic);
    applyFilters();
  }

  function filterMonth(month, btn) {
    document.querySelectorAll('.month-btn').forEach(function(b) { b.classList.remove('active'); });
    if (btn) btn.classList.add('active');
    activeMonth = month;
    localStorage.setItem('positiviteiten-month', month);
    applyFilters();
  }

  (function() {
    var savedTopic = localStorage.getItem('positiviteiten-topic');
    var savedMonth = localStorage.getItem('positiviteiten-month');
    if (savedTopic && savedTopic !== 'all') {
      var btn = document.querySelector('.topic-btn[data-topic="' + savedTopic + '"]');
      if (btn) { activeTag = savedTopic; document.querySelectorAll('.topic-btn').forEach(function(b) { b.classList.remove('active'); }); btn.classList.add('active'); }
    }
    if (savedMonth && savedMonth !== 'all') {
      var btn2 = document.querySelector('.month-btn[data-month="' + savedMonth + '"]');
      if (btn2) { activeMonth = savedMonth; document.querySelectorAll('.month-btn').forEach(function(b) { b.classList.remove('active'); }); btn2.classList.add('active'); }
    }
    if (activeTag !== 'all' || activeMonth !== 'all') applyFilters();
  })();
</script>
