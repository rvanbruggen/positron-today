---
layout: base.njk
---

<style>
  .post-back {
    font-size: 0.8rem; color: #b45309; text-decoration: none;
    display: inline-block; margin-bottom: 1.25rem;
    min-height: 36px; line-height: 36px;
    -webkit-tap-highlight-color: transparent;
  }
  .post-back:hover { color: #78350f; }

  /* Accent colours — driven by topic at build time */
  :root {
    --accent-bg: #fef9c3; --accent-border: #fde047;
    --accent-text: #713f12; --accent-muted: #b45309;
  }
  .accent-orange { --accent-bg:#ffedd5; --accent-border:#fb923c; --accent-text:#7c2d12; --accent-muted:#c2410c; }
  .accent-rose   { --accent-bg:#ffe4e6; --accent-border:#fb7185; --accent-text:#881337; --accent-muted:#be123c; }
  .accent-purple { --accent-bg:#f3e8ff; --accent-border:#c084fc; --accent-text:#581c87; --accent-muted:#7e22ce; }
  .accent-blue   { --accent-bg:#dbeafe; --accent-border:#60a5fa; --accent-text:#1e3a5f; --accent-muted:#1d4ed8; }
  .accent-cyan   { --accent-bg:#cffafe; --accent-border:#22d3ee; --accent-text:#164e63; --accent-muted:#0891b2; }
  .accent-teal   { --accent-bg:#ccfbf1; --accent-border:#2dd4bf; --accent-text:#134e4a; --accent-muted:#0d9488; }
  .accent-green  { --accent-bg:#dcfce7; --accent-border:#4ade80; --accent-text:#14532d; --accent-muted:#15803d; }
  .accent-lime   { --accent-bg:#ecfccb; --accent-border:#a3e635; --accent-text:#365314; --accent-muted:#4d7c0f; }
  .accent-pink   { --accent-bg:#fce7f3; --accent-border:#f472b6; --accent-text:#831843; --accent-muted:#be185d; }

  .post-header {
    background: var(--accent-bg); border: 2px solid var(--accent-border);
    border-radius: 1rem; padding: 1.1rem; margin-bottom: 1.25rem;
  }
  .post-emoji { font-size: 2rem; margin-bottom: 0.4rem; }
  .post-topic { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-muted); margin-bottom: 0.4rem; }
  .post-title {
    font-size: clamp(1.15rem, 4.5vw, 1.5rem);
    font-weight: 700; color: var(--accent-text); line-height: 1.3; margin-bottom: 0.6rem;
  }
  .post-meta { font-size: 0.8rem; color: var(--accent-muted); }

  .lang-tabs { display: flex; gap: 0.4rem; margin-bottom: 1rem; flex-wrap: wrap; }
  .lang-tab {
    padding: 0.4rem 0.9rem; border-radius: 99px; font-size: 0.75rem;
    font-weight: 600; cursor: pointer; border: none;
    background: #fef3c7; color: #92400e; transition: background 0.15s;
    -webkit-tap-highlight-color: transparent; min-height: 36px;
  }
  .lang-tab.active { background: var(--accent-border); color: var(--accent-text); }

  .post-body {
    background: white; border-radius: 1rem; padding: 1.1rem;
    border: 2px solid var(--accent-border);
    font-size: clamp(0.875rem, 2.5vw, 0.95rem);
    line-height: 1.75; color: #451a03; margin-bottom: 1.25rem;
  }

  .post-source {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: var(--accent-bg); border: 2px solid var(--accent-border);
    border-radius: 0.5rem; padding: 0.6rem 1rem; font-size: 0.875rem;
    font-weight: 500; color: var(--accent-text); text-decoration: none;
    min-height: 44px; /* comfortable touch target */
    -webkit-tap-highlight-color: transparent;
  }
  .post-source:hover { filter: brightness(0.95); }

  @media (min-width: 640px) {
    .post-header { padding: 1.5rem; }
    .post-emoji { font-size: 2.5rem; }
    .post-body { padding: 1.5rem; }
  }
</style>

{# Apply topic-based accent at build time #}
<script>document.documentElement.classList.add('accent-{{ topic | topicColor }}');</script>

<a href="/positiviteiten/" class="post-back">← Back to all posts</a>

<div class="lang-tabs">
  <button class="lang-tab active" onclick="setLang('en', this)">EN</button>
  <button class="lang-tab" onclick="setLang('nl', this)">NL</button>
  <button class="lang-tab" onclick="setLang('fr', this)">FR</button>
</div>

<div class="post-header">
  <div class="post-emoji">{{ emoji }}</div>
  <div class="post-topic">{{ topic }}</div>
  <h1 class="post-title">
    <span class="t-en">{{ title }}</span>
    <span class="t-nl" style="display:none">{{ title_nl if title_nl else title }}</span>
    <span class="t-fr" style="display:none">{{ title_fr if title_fr else title }}</span>
  </h1>
  <p class="post-meta">{{ source_name }} · {{ page.date | dateDisplay }}</p>
</div>

<div class="post-body">
  <span class="t-en">{{ summary }}</span>
  <span class="t-nl" style="display:none">{{ summary_nl if summary_nl else summary }}</span>
  <span class="t-fr" style="display:none">{{ summary_fr if summary_fr else summary }}</span>
</div>

<a href="{{ source_url }}" target="_blank" rel="noopener noreferrer" class="post-source">
  Read the original article ↗
</a>

<script>
  const LANGS = ['en', 'nl', 'fr'];
  function setLang(lang, btn) {
    LANGS.forEach(function(l) {
      document.querySelectorAll('.t-' + l).forEach(function(el) {
        el.style.display = l === lang ? '' : 'none';
      });
    });
    document.querySelectorAll('.lang-tab').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    localStorage.setItem('positiviteiten-lang', lang);
  }
  (function() {
    var saved = localStorage.getItem('positiviteiten-lang');
    if (saved && saved !== 'en') {
      var btn = document.querySelector('.lang-tab[onclick*="' + saved + '"]');
      if (btn) setLang(saved, btn);
    }
  })();
</script>
