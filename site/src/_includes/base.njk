<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} - {% endif %}Positiviteiten</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #fffbeb;
      color: #451a03;
      min-height: 100vh;
      -webkit-text-size-adjust: 100%;
    }

    /* ── Nav ── */
    nav {
      background: #facc15;
      padding: 0.65rem 1rem;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
    }
    nav .brand {
      font-size: 1.1rem; font-weight: 700;
      text-decoration: none; color: #78350f;
      margin-right: 0.25rem;
    }
    nav .nav-links {
      display: flex; align-items: center; gap: 0.75rem;
    }
    nav a { color: #78350f; text-decoration: none; font-size: 0.875rem; font-weight: 500; }
    nav a:hover { color: #d97706; }

    /* ── Main content ── */
    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1.5rem 1rem;
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 1.5rem 1rem;
      font-size: 0.75rem;
      color: #92400e;
    }

    /* ── Desktop upgrades ── */
    @media (min-width: 640px) {
      nav { padding: 0.75rem 1.5rem; gap: 0.75rem 1.5rem; }
      nav .brand { font-size: 1.25rem; }
      main { padding: 2.5rem 1.5rem; }
      footer { padding: 2rem; }
    }
  </style>
</head>
<body>
  <nav>
    <a href="/positiviteiten/" class="brand">✨ Positiviteiten</a>
    <div class="nav-links">
      <a href="/positiviteiten/about/">About</a>
      <a href="/positiviteiten/contact/">Contact</a>
    </div>
  </nav>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    Positiviteiten &nbsp;·&nbsp; positive news, every day &nbsp;·&nbsp; v{{ meta.version }}
  </footer>
</body>
</html>
