<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} - {% endif %}Positiviteiten</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #fffbeb;
      color: #451a03;
      min-height: 100vh;
      -webkit-text-size-adjust: 100%;
      position: relative;
    }

    /* ── Watermark — large faint logo behind all content ── */
    .page-watermark {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -44%);
      width: 680px;
      height: 680px;
      opacity: 0.10;
      pointer-events: none;
      z-index: 0;
    }
    nav, main, footer { position: relative; z-index: 1; }

    /* ── Nav ── */
    nav {
      background: #facc15;
      padding: 0.65rem 1rem;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
    }
    nav .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.1rem; font-weight: 700;
      text-decoration: none; color: #78350f;
      margin-right: 0.25rem;
    }
    nav .brand svg { flex-shrink: 0; }
    nav .nav-links {
      display: flex; align-items: center; gap: 0.75rem;
    }
    nav a { color: #78350f; text-decoration: none; font-size: 0.875rem; font-weight: 500; }
    nav a:hover { color: #d97706; }

    /* ── Main content ── */
    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1.5rem 1rem;
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 1.5rem 1rem;
      font-size: 0.75rem;
      color: #92400e;
    }

    /* ── Desktop upgrades ── */
    @media (min-width: 640px) {
      nav { padding: 0.75rem 1.5rem; gap: 0.75rem 1.5rem; }
      nav .brand { font-size: 1.25rem; }
      nav .brand svg { width: 38px; height: 38px; }
      main { padding: 2.5rem 1.5rem; }
      footer { padding: 2rem; }
    }
  </style>
</head>
<body>

  <!-- Large faint logo watermark (dark amber = good contrast on cream) -->
  <div class="page-watermark" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="100%" height="100%">
      <path fill="#78350f"
        d="M15,10 L85,10 Q92,10 92,17 L92,62 Q92,70 85,70 L58,70 L50,84 L42,70 L15,70 Q8,70 8,62 L8,17 Q8,10 15,10 Z"/>
      <polygon fill="#fffbeb"
        points="50,20 54,31 66,32 57,39 60,51 50,44 40,51 43,39 34,32 46,31"/>
      <circle fill="#fffbeb" cx="22" cy="22" r="2.5"/>
      <circle fill="#fffbeb" cx="78" cy="22" r="2.5"/>
      <circle fill="#fffbeb" cx="80" cy="57" r="1.8"/>
      <circle fill="#fffbeb" cx="20" cy="57" r="1.8"/>
    </svg>
  </div>

  <nav>
    <a href="/positiviteiten/" class="brand">
      <!-- Speech-bubble-with-star logo -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="32" height="32" aria-hidden="true">
        <path fill="#f59e0b"
          d="M15,10 L85,10 Q92,10 92,17 L92,62 Q92,70 85,70 L58,70 L50,84 L42,70 L15,70 Q8,70 8,62 L8,17 Q8,10 15,10 Z"/>
        <polygon fill="white" opacity="0.92"
          points="50,20 54,31 66,32 57,39 60,51 50,44 40,51 43,39 34,32 46,31"/>
        <circle fill="white" opacity="0.55" cx="22" cy="22" r="2.5"/>
        <circle fill="white" opacity="0.55" cx="78" cy="22" r="2.5"/>
        <circle fill="white" opacity="0.40" cx="80" cy="57" r="1.8"/>
        <circle fill="white" opacity="0.40" cx="20" cy="57" r="1.8"/>
      </svg>
      Positiviteiten
    </a>
    <div class="nav-links">
      <a href="/positiviteiten/about/">About</a>
      <a href="/positiviteiten/negativity/" id="nav-skip">What we skip</a>
      <a href="/positiviteiten/contact/">Contact</a>
    </div>
  </nav>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    Positiviteiten &nbsp;·&nbsp; positive news, every day &nbsp;·&nbsp; v{{ meta.version }}
  </footer>
  <script>
    // Apply saved language to the nav link label
    (function() {
      var labels = { en: 'What we skip', nl: 'Wat we overslaan', fr: 'Ce qu\'on ignore' };
      var lang = localStorage.getItem('positiviteiten-lang') || 'en';
      var el = document.getElementById('nav-skip');
      if (el && labels[lang]) el.textContent = labels[lang];
    })();
  </script>
</body>
</html>
