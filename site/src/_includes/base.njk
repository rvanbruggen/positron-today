<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} - {% endif %}Positron Today</title>

  {# ── SEO: description ── #}
  {% set metaDesc = description if description else "Positron Today — positive news, curated by AI, published every day. Good things are happening; we make sure you hear about them." %}
  <meta name="description" content="{{ metaDesc }}">

  {# ── SEO: canonical URL ── #}
  {% set canonicalUrl = meta.siteUrl + page.url %}
  <link rel="canonical" href="{{ canonicalUrl }}">

  {# ── Open Graph ── #}
  <meta property="og:type"        content="{% if layout == 'post.njk' %}article{% else %}website{% endif %}">
  <meta property="og:site_name"   content="Positron Today">
  <meta property="og:title"       content="{% if title %}{{ title }}{% else %}Positron Today{% endif %}">
  <meta property="og:description" content="{{ metaDesc }}">
  <meta property="og:url"         content="{{ canonicalUrl }}">
  {% if image_url %}
  <meta property="og:image"       content="{{ image_url }}">
  {% else %}
  <meta property="og:image"       content="{{ meta.siteUrl }}/assets/og-default.png">
  {% endif %}

  {# ── Twitter / X card ── #}
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:site"        content="@positron_today">
  <meta name="twitter:title"       content="{% if title %}{{ title }}{% else %}Positron Today{% endif %}">
  <meta name="twitter:description" content="{{ metaDesc }}">
  {% if image_url %}
  <meta name="twitter:image"       content="{{ image_url }}">
  {% else %}
  <meta name="twitter:image"       content="{{ meta.siteUrl }}/assets/og-default.png">
  {% endif %}

  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
  <link rel="alternate" type="application/rss+xml" title="Positron Today (English)" href="https://positron.today/feed.xml">
  <link rel="alternate" type="application/rss+xml" title="Positron Today (Nederlands)" href="https://positron.today/feed-nl.xml">
  <link rel="alternate" type="application/rss+xml" title="Positron Today (Français)" href="https://positron.today/feed-fr.xml">
  <link rel="stylesheet" href="/assets/themes.css">
  <script>
    // Resolve language: URL ?lang= param takes priority, then localStorage, then 'en'.
    // URL param wins so that a shared link always overrides whatever the visitor
    // had stored locally.
    (function() {
      var VALID = ['en', 'nl', 'fr'];
      var urlLang = new URLSearchParams(window.location.search).get('lang');
      var lang = (urlLang && VALID.indexOf(urlLang) !== -1)
        ? urlLang
        : (localStorage.getItem('positron-today-lang') || 'en');
      if (urlLang && VALID.indexOf(urlLang) !== -1) {
        localStorage.setItem('positron-today-lang', urlLang);
      }
      // Apply immediately so CSS hides the wrong-language spans before first paint.
      document.documentElement.setAttribute('data-lang', lang);

      // Resolve theme: localStorage, default 'classic'. No FOUC — set on <html>
      // before the body renders so themes.css overrides apply on first paint.
      var VALID_THEMES = ['classic', 'mono', 'mondrian'];
      var theme = localStorage.getItem('positron-today-theme') || 'classic';
      if (VALID_THEMES.indexOf(theme) === -1) theme = 'classic';
      document.documentElement.setAttribute('data-theme', theme);
    })();

    // Set the active theme. Persists to localStorage. Page content does not
    // need JS re-rendering: CSS in themes.css keys off html[data-theme="..."].
    function setTheme(theme) {
      var VALID_THEMES = ['classic', 'mono', 'mondrian'];
      if (VALID_THEMES.indexOf(theme) === -1) theme = 'classic';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('positron-today-theme', theme);
    }

    // Updates the page URL to reflect the active language without a reload.
    // English is the default so it gets no param (cleaner URLs).
    // Called by setLang and all page-specific overrides so every page is shareable.
    function _updateLangUrl(lang) {
      try {
        var u = new URL(window.location.href);
        if (lang === 'en') { u.searchParams.delete('lang'); }
        else               { u.searchParams.set('lang', lang); }
        history.replaceState(null, '', u.toString());
      } catch(e) {}
    }

    // Define setLang early (in <head>) so it is available to all page scripts
    // before base.njk's closing <script> block runs.
    // Pages that need extra block toggling (about, contact) override this
    // in their own <script> block; because base.njk's bottom script no longer
    // redefines setLang, the page-specific override persists for nav-button clicks.
    function setLang(lang, btn) {
      document.documentElement.setAttribute('data-lang', lang);
      _updateLangUrl(lang);
      ['en','nl','fr'].forEach(function(l) {
        document.querySelectorAll('.t-' + l).forEach(function(el) {
          el.style.display = l === lang ? '' : 'none';
        });
      });
      // btn arg kept for backwards compat with page-specific overrides
      // (about, contact, negativity) that call setLang(saved, btn).
      localStorage.setItem('positron-today-lang', lang);
    }
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #fffbeb;
      color: #451a03;
      min-height: 100vh;
      -webkit-text-size-adjust: 100%;
      position: relative;
    }

    /* ── Watermark — large faint logo behind all content ── */
    .page-watermark {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -44%);
      width: 680px;
      height: 680px;
      opacity: 0.10;
      pointer-events: none;
      z-index: 0;
    }
    nav, main, footer { position: relative; z-index: 1; }

    /* ── Nav ── */
    nav {
      background: #facc15;
      padding: 0.65rem 1rem;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
    }
    nav .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.1rem; font-weight: 700;
      text-decoration: none; color: #78350f;
      margin-right: 0.25rem;
    }
    nav .brand svg { flex-shrink: 0; }
    nav .nav-links {
      display: flex; align-items: center; gap: 0.75rem;
    }
    nav a { color: #78350f; text-decoration: none; font-size: 0.875rem; font-weight: 500; }
    nav a:hover { color: #d97706; }
    nav .nav-lang { display: flex; align-items: center; gap: 0.4rem; margin-left: auto; flex-wrap: wrap; }

    /* ── Main content ── */
    main {
      max-width: 1400px;
      margin: 0 auto;
      padding: 1.5rem 1rem;
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 1.5rem 1rem;
      font-size: 0.75rem;
      color: #92400e;
    }

    /* ── Language-controlled nav & footer spans (no FOUC) ──
       The <head> script sets data-lang on <html> before the body renders,
       so these rules apply before any span is painted.                   */
    nav .t-nl, nav .t-fr,
    footer .t-nl, footer .t-fr { display: none; }
    html[data-lang="nl"] nav .t-en,
    html[data-lang="nl"] footer .t-en { display: none; }
    html[data-lang="nl"] nav .t-nl,
    html[data-lang="nl"] footer .t-nl { display: inline; }
    html[data-lang="fr"] nav .t-en,
    html[data-lang="fr"] footer .t-en { display: none; }
    html[data-lang="fr"] nav .t-fr,
    html[data-lang="fr"] footer .t-fr { display: inline; }

    /* ── Desktop upgrades ── */
    @media (min-width: 640px) {
      nav { padding: 0.75rem 1.5rem; gap: 0.75rem 1.5rem; }
      nav .brand { font-size: 1.25rem; }
      nav .brand svg { width: 38px; height: 38px; }
      main { padding: 2.5rem 1.5rem; }
      footer { padding: 2rem; }
    }
  </style>
  <!-- Umami analytics — privacy-friendly, no cookies, no consent banner needed -->
  <script defer src="https://cloud.umami.is/script.js" data-website-id="0d24bd86-4992-4b7f-b95c-53b4dafe9eae"></script>
</head>
<body>

  <!-- Large faint logo watermark (dark amber = good contrast on cream) -->
  <div class="page-watermark" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="100%" height="100%">
      <!-- Three orbital ellipses -->
      <ellipse cx="50" cy="50" rx="47" ry="16" fill="none" stroke="#78350f" stroke-width="4"/>
      <ellipse cx="50" cy="50" rx="47" ry="16" fill="none" stroke="#78350f" stroke-width="4" transform="rotate(60 50 50)"/>
      <ellipse cx="50" cy="50" rx="47" ry="16" fill="none" stroke="#78350f" stroke-width="4" transform="rotate(120 50 50)"/>
      <!-- Nucleus -->
      <circle cx="50" cy="50" r="13" fill="#78350f"/>
      <!-- Plus sign (positron = positive charge) -->
      <rect x="43.5" y="47" width="13" height="6" rx="2" fill="#fffbeb"/>
      <rect x="47" y="43.5" width="6" height="13" rx="2" fill="#fffbeb"/>
    </svg>
  </div>

  <nav>
    <a href="/" class="brand">
      <!-- Classic: amber atom with + nucleus -->
      <svg class="brand-logo-classic" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="32" height="32" aria-hidden="true">
        <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="#f59e0b" stroke-width="5"/>
        <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="#f59e0b" stroke-width="5" transform="rotate(60 50 50)"/>
        <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="#f59e0b" stroke-width="5" transform="rotate(120 50 50)"/>
        <circle cx="50" cy="50" r="13" fill="#f59e0b"/>
        <rect x="43.5" y="47" width="13" height="6" rx="2" fill="white" opacity="0.95"/>
        <rect x="47" y="43.5" width="6" height="13" rx="2" fill="white" opacity="0.95"/>
      </svg>
      <!-- Mono: black atom, no plus (clean modern mark) -->
      <svg class="brand-logo-mono" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="32" height="32" aria-hidden="true">
        <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="#111" stroke-width="5"/>
        <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="#111" stroke-width="5" transform="rotate(60 50 50)"/>
        <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="#111" stroke-width="5" transform="rotate(120 50 50)"/>
        <circle cx="50" cy="50" r="10" fill="#111"/>
      </svg>
      <!-- Mondrian: positron atom rendered in De Stijl palette.
           Three orbitals in red / blue / black (primary + neutral), yellow
           nucleus with a bold black plus — same atomic structure as the
           classic logo, restyled with thick strokes and primary colors. -->
      <svg class="brand-logo-mondrian" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="32" height="32" aria-hidden="true">
        <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="#e63946" stroke-width="7"/>
        <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="#1d4ed8" stroke-width="7" transform="rotate(60 50 50)"/>
        <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="#111111" stroke-width="7" transform="rotate(120 50 50)"/>
        <circle cx="50" cy="50" r="15" fill="#facc15" stroke="#111111" stroke-width="5"/>
        <rect x="42.5" y="46.5" width="15" height="7" fill="#111111"/>
        <rect x="46.5" y="42.5" width="7" height="15" fill="#111111"/>
      </svg>
      Positron Today
    </a>
    <div class="nav-links">
      <a href="/about/">
        <span class="t-en">About</span>
        <span class="t-nl">Over ons</span>
        <span class="t-fr">À propos</span>
      </a>
      <a href="/archive/">
        <span class="t-en">Archive</span>
        <span class="t-nl">Archief</span>
        <span class="t-fr">Archives</span>
      </a>
      <a href="/negativity/">
        <span class="t-en">What we skip</span>
        <span class="t-nl">Wat we overslaan</span>
        <span class="t-fr">Ce qu'on ignore</span>
      </a>
      <a href="/contact/">Contact</a>
    </div>
    <div class="nav-lang">
      <select class="nav-select" id="nav-lang-select" aria-label="Language"
              onchange="if(this.value){setLang(this.value);}this.selectedIndex=0;">
        <option value="" selected>Language</option>
        <option value="en">English</option>
        <option value="nl">Nederlands</option>
        <option value="fr">Français</option>
      </select>
      <select class="nav-select" id="nav-theme-select" aria-label="Colours"
              onchange="if(this.value){setTheme(this.value);}this.selectedIndex=0;">
        <option value="" selected>Colours</option>
        <option value="classic">Classic</option>
        <option value="mono">Mono</option>
        <option value="mondrian">Mondrian</option>
      </select>
    </div>
  </nav>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    Positron Today &nbsp;·&nbsp;
    <span class="t-en">positive news, every day</span>
    <span class="t-nl">positief nieuws, elke dag</span>
    <span class="t-fr">actualités positives, chaque jour</span>
    &nbsp;·&nbsp;
    <span class="t-en"><a href="/feed.xml" style="color:inherit;text-decoration:none;" title="RSS feed (English)">RSS ↗</a></span>
    <span class="t-nl"><a href="/feed-nl.xml" style="color:inherit;text-decoration:none;" title="RSS-feed (Nederlands)">RSS ↗</a></span>
    <span class="t-fr"><a href="/feed-fr.xml" style="color:inherit;text-decoration:none;" title="Flux RSS (Français)">RSS ↗</a></span>
    &nbsp;·&nbsp; v{{ meta.version }}
  </footer>
  <script>
    // Restore saved language on every page load.
    // setLang is already defined in <head> (or overridden by a page-specific
    // script for about/contact), so it is always available here.
    // Theme is already applied in <head> before first paint; no restore needed.
    // The dropdowns always show their placeholder label ("Language" / "Colours")
    // so we deliberately do NOT sync them to the active value.
    (function() {
      var lang = localStorage.getItem('positron-today-lang') || 'en';
      if (lang !== 'en') setLang(lang);
    })();
  </script>
</body>
</html>
