<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} - {% endif %}Positiviteiten</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #fffbeb;
      color: #451a03;
      min-height: 100vh;
    }
    nav {
      background: #facc15;
      padding: 0.75rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    nav .brand { font-size: 1.25rem; font-weight: 700; text-decoration: none; color: #78350f; }
    nav a { color: #78350f; text-decoration: none; font-size: 0.875rem; font-weight: 500; }
    nav a:hover { color: #d97706; }
    main { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem; }
    footer { text-align: center; padding: 2rem; font-size: 0.75rem; color: #92400e; }
  </style>
</head>
<body>
  <nav>
    <a href="/positiviteiten/" class="brand">✨ Positiviteiten</a>
    <a href="/positiviteiten/about/">About</a>
    <a href="/positiviteiten/contact/">Contact</a>
  </nav>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    Positiviteiten - positive news, every day.
  </footer>
</body>
</html>
