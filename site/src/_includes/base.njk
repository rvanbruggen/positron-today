<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} - {% endif %}Positiviteiten</title>
  <script>
    // Define setLang early (in <head>) so it is available to all page scripts
    // before base.njk's closing <script> block runs.
    // Pages that need extra block toggling (about, contact) override this
    // in their own <script> block; because base.njk's bottom script no longer
    // redefines setLang, the page-specific override persists for nav-button clicks.
    function setLang(lang, btn) {
      ['en','nl','fr'].forEach(function(l) {
        document.querySelectorAll('.t-' + l).forEach(function(el) {
          el.style.display = l === lang ? '' : 'none';
        });
      });
      document.querySelectorAll('.nav-lang-btn').forEach(function(b) { b.classList.remove('active'); });
      if (btn) btn.classList.add('active');
      localStorage.setItem('positiviteiten-lang', lang);
    }
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #fffbeb;
      color: #451a03;
      min-height: 100vh;
      -webkit-text-size-adjust: 100%;
      position: relative;
    }

    /* ── Watermark — large faint logo behind all content ── */
    .page-watermark {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -44%);
      width: 680px;
      height: 680px;
      opacity: 0.10;
      pointer-events: none;
      z-index: 0;
    }
    nav, main, footer { position: relative; z-index: 1; }

    /* ── Nav ── */
    nav {
      background: #facc15;
      padding: 0.65rem 1rem;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
    }
    nav .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.1rem; font-weight: 700;
      text-decoration: none; color: #78350f;
      margin-right: 0.25rem;
    }
    nav .brand svg { flex-shrink: 0; }
    nav .nav-links {
      display: flex; align-items: center; gap: 0.75rem;
    }
    nav a { color: #78350f; text-decoration: none; font-size: 0.875rem; font-weight: 500; }
    nav a:hover { color: #d97706; }
    nav .nav-lang { display: flex; align-items: center; gap: 0.25rem; margin-left: auto; }
    .nav-lang-btn {
      background: transparent;
      border: 1.5px solid rgba(120,53,15,0.3);
      color: #78350f; font-size: 0.72rem; font-weight: 700;
      padding: 0.2rem 0.55rem; border-radius: 99px; cursor: pointer;
      transition: background 0.12s, color 0.12s;
      -webkit-tap-highlight-color: transparent; line-height: 1.4;
    }
    .nav-lang-btn:hover:not(.active) { background: rgba(120,53,15,0.1); }
    .nav-lang-btn.active { background: #78350f; color: #facc15; border-color: #78350f; }

    /* ── Main content ── */
    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1.5rem 1rem;
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 1.5rem 1rem;
      font-size: 0.75rem;
      color: #92400e;
    }

    /* ── Desktop upgrades ── */
    @media (min-width: 640px) {
      nav { padding: 0.75rem 1.5rem; gap: 0.75rem 1.5rem; }
      nav .brand { font-size: 1.25rem; }
      nav .brand svg { width: 38px; height: 38px; }
      main { padding: 2.5rem 1.5rem; }
      footer { padding: 2rem; }
    }
  </style>
</head>
<body>

  <!-- Large faint logo watermark (dark amber = good contrast on cream) -->
  <div class="page-watermark" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="100%" height="100%">
      <path fill="#78350f"
        d="M15,10 L85,10 Q92,10 92,17 L92,62 Q92,70 85,70 L58,70 L50,84 L42,70 L15,70 Q8,70 8,62 L8,17 Q8,10 15,10 Z"/>
      <polygon fill="#fffbeb"
        points="50,20 54,31 66,32 57,39 60,51 50,44 40,51 43,39 34,32 46,31"/>
      <circle fill="#fffbeb" cx="22" cy="22" r="2.5"/>
      <circle fill="#fffbeb" cx="78" cy="22" r="2.5"/>
      <circle fill="#fffbeb" cx="80" cy="57" r="1.8"/>
      <circle fill="#fffbeb" cx="20" cy="57" r="1.8"/>
    </svg>
  </div>

  <nav>
    <a href="/positiviteiten/" class="brand">
      <!-- Speech-bubble-with-star logo -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="32" height="32" aria-hidden="true">
        <path fill="#f59e0b"
          d="M15,10 L85,10 Q92,10 92,17 L92,62 Q92,70 85,70 L58,70 L50,84 L42,70 L15,70 Q8,70 8,62 L8,17 Q8,10 15,10 Z"/>
        <polygon fill="white" opacity="0.92"
          points="50,20 54,31 66,32 57,39 60,51 50,44 40,51 43,39 34,32 46,31"/>
        <circle fill="white" opacity="0.55" cx="22" cy="22" r="2.5"/>
        <circle fill="white" opacity="0.55" cx="78" cy="22" r="2.5"/>
        <circle fill="white" opacity="0.40" cx="80" cy="57" r="1.8"/>
        <circle fill="white" opacity="0.40" cx="20" cy="57" r="1.8"/>
      </svg>
      <span class="t-en">Positivities</span>
      <span class="t-nl" style="display:none">Positiviteiten</span>
      <span class="t-fr" style="display:none">Positivités</span>
    </a>
    <div class="nav-links">
      <a href="/positiviteiten/about/">
        <span class="t-en">About</span>
        <span class="t-nl" style="display:none">Over ons</span>
        <span class="t-fr" style="display:none">À propos</span>
      </a>
      <a href="/positiviteiten/negativity/">
        <span class="t-en">What we skip</span>
        <span class="t-nl" style="display:none">Wat we overslaan</span>
        <span class="t-fr" style="display:none">Ce qu'on ignore</span>
      </a>
      <a href="/positiviteiten/contact/">Contact</a>
    </div>
    <div class="nav-lang">
      <button class="nav-lang-btn active" onclick="setLang('en',this)">EN</button>
      <button class="nav-lang-btn" onclick="setLang('nl',this)">NL</button>
      <button class="nav-lang-btn" onclick="setLang('fr',this)">FR</button>
    </div>
  </nav>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    Positiviteiten &nbsp;·&nbsp;
    <span class="t-en">positive news, every day</span>
    <span class="t-nl" style="display:none">positief nieuws, elke dag</span>
    <span class="t-fr" style="display:none">actualités positives, chaque jour</span>
    &nbsp;·&nbsp; v{{ meta.version }}
  </footer>
  <script>
    // Restore saved language on every page load.
    // setLang is already defined in <head> (or overridden by a page-specific
    // script for about/contact), so it is always available here.
    (function() {
      var lang = localStorage.getItem('positiviteiten-lang') || 'en';
      if (lang !== 'en') {
        var btn = document.querySelector('.nav-lang-btn[onclick*="' + lang + '"]');
        setLang(lang, btn);
      }
    })();
  </script>
</body>
</html>
