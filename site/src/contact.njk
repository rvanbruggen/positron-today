<script>
  // Override global setLang to also toggle contact-block visibility
  function setLang(lang, btn) {
    document.documentElement.setAttribute('data-lang', lang);
    _updateLangUrl(lang);
    ['en','nl','fr'].forEach(function(l) {
      document.querySelectorAll('.t-' + l).forEach(function(el) { el.style.display = l === lang ? '' : 'none'; });
      var block = document.getElementById('contact-' + l);
      if (block) block.className = 'contact-block' + (l === lang ? ' visible' : '');
    });
    document.querySelectorAll('.nav-lang-btn').forEach(function(b) { b.classList.remove('active'); });
    if (btn) btn.classList.add('active');
    localStorage.setItem('positron-today-lang', lang);
  }
  (function() {
    var saved = localStorage.getItem('positron-today-lang');
    if (saved && saved !== 'en') {
      var btn = document.querySelector('.nav-lang-btn[onclick*="' + saved + '"]');
      setLang(saved, btn);
    }
  })();
</script>
