<script>
  var ABOUT_LANGS = ['en', 'nl', 'fr'];
  var ABOUT_BLOCKS = ['about', 'why'];

  // Override global setLang to also toggle about-prose block visibility
  function setLang(lang, btn) {
    document.documentElement.setAttribute('data-lang', lang);
    _updateLangUrl(lang);
    ABOUT_LANGS.forEach(function(l) {
      ABOUT_BLOCKS.forEach(function(block) {
        var el = document.getElementById(block + '-' + l);
        if (el) el.className = 'about-prose' + (l === lang ? ' visible' : '');
      });
      document.querySelectorAll('.t-' + l).forEach(function(el) {
        el.style.display = l === lang ? '' : 'none';
      });
    });
    document.querySelectorAll('.nav-lang-btn').forEach(function(b) { b.classList.remove('active'); });
    if (btn) btn.classList.add('active');
    localStorage.setItem('positron-today-lang', lang);
  }

  // Restore saved language on load
  (function() {
    var saved = localStorage.getItem('positron-today-lang');
    if (saved && saved !== 'en') {
      var btn = document.querySelector('.nav-lang-btn[onclick*="' + saved + '"]');
      setLang(saved, btn);
    }
  })();
</script>
