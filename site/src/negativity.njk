---
layout: base.njk
title: The News We Skip
---

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: clamp(1.35rem,5vw,1.75rem); font-weight:700; color:#78350f; margin-bottom:0.5rem; }
  .page-header p  { font-size:0.9rem; color:#b45309; line-height:1.6; }

  /* ── Summary stats ── */
  .stat-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(120px,1fr)); gap:1rem; margin-bottom:2rem; }
  .stat-card { background:#fff; border:2px solid #fde047; border-radius:1rem; padding:1.25rem 1rem; text-align:center; }
  .stat-num  { font-size:2rem; font-weight:700; color:#78350f; }
  .stat-lbl  { font-size:0.75rem; color:#b45309; margin-top:0.25rem; }

  /* ── Category breakdown chart ── */
  .breakdown-section { background:#fff; border:1.5px solid #fde68a; border-radius:1rem; padding:1.25rem 1.5rem; margin-bottom:2rem; }
  .breakdown-title { font-size:0.75rem; font-weight:700; color:#b45309; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:1rem; }
  .breakdown-row { display:flex; align-items:center; gap:0.6rem; margin-bottom:0.55rem; }
  .breakdown-label { font-size:0.78rem; color:#78350f; width:180px; flex-shrink:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .breakdown-bar-wrap { flex:1; height:8px; background:#fef3c7; border-radius:99px; overflow:hidden; }
  .breakdown-bar { height:100%; border-radius:99px; }
  .breakdown-count { font-size:0.72rem; color:#b45309; width:42px; text-align:right; flex-shrink:0; }

  /* ── Filter bar ── */
  .filter-bar { display:flex; gap:0.5rem; margin-bottom:1.25rem; flex-wrap:wrap; }
  .cat-pill {
    padding:0.3rem 0.8rem; border-radius:99px; font-size:0.75rem; font-weight:600;
    cursor:pointer; border:1.5px solid #fde68a; background:#fff; color:#78350f;
    transition:background 0.15s; white-space:nowrap;
  }
  .cat-pill.active { background:#facc15; border-color:#f59e0b; }

  /* ── Article cards ── */
  .rejection-list { display:flex; flex-direction:column; gap:0.75rem; }
  .rejection-card {
    background:#fff7ed; border:1.5px solid #fde68a; border-radius:0.75rem;
    padding:0.9rem 1.1rem;
  }
  .rejection-card[data-cat] { border-left-width:4px; }
  .rejection-title { font-size:0.9rem; font-weight:600; color:#78350f; line-height:1.4; }
  .rejection-meta  { font-size:0.75rem; color:#b45309; margin-top:0.3rem; display:flex; gap:0.75rem; flex-wrap:wrap; align-items:center; }
  .cat-badge {
    display:inline-flex; align-items:center; gap:0.3rem;
    font-size:0.7rem; font-weight:600; padding:0.15rem 0.55rem;
    border-radius:99px; border:1px solid currentColor;
  }
  .rejection-reason { font-size:0.82rem; color:#92400e; margin-top:0.5rem; line-height:1.55; }
  .rejection-reason::before { content:"✗ "; color:#ef4444; }

  .empty { color:#b45309; font-size:0.9rem; }
  .updated { font-size:0.75rem; color:#d97706; margin-bottom:1.5rem; }

  /* ── Section headings ── */
  .section-heading {
    font-size:1.1rem; font-weight:700; color:#78350f;
    margin:2rem 0 0.75rem; padding-bottom:0.5rem;
    border-bottom:2px solid #fde68a;
  }

  /* ── Pagination controls ── */
  .pagination-bar {
    display:flex; align-items:center; gap:0.5rem;
    flex-wrap:wrap; margin-bottom:1.25rem;
  }
  .page-size-label { font-size:0.75rem; color:#b45309; white-space:nowrap; }
  .page-size-select {
    padding:0.3rem 0.6rem; border-radius:0.5rem; font-size:0.78rem;
    border:1.5px solid #fde68a; background:#fff; color:#78350f;
    font-family:inherit; cursor:pointer;
  }
  .page-size-select:focus { outline:none; border-color:#f59e0b; }
  .page-info { font-size:0.75rem; color:#b45309; margin-left:auto; white-space:nowrap; }
  .page-btn {
    padding:0.3rem 0.75rem; border-radius:0.5rem; font-size:0.78rem; font-weight:600;
    border:1.5px solid #fde68a; background:#fff; color:#78350f;
    cursor:pointer; transition:background 0.15s;
  }
  .page-btn:hover:not(:disabled) { background:#fef3c7; }
  .page-btn:disabled { opacity:0.35; cursor:default; }
</style>

{% set catMeta = {
  "war-conflict":            { label_en: "War & Conflict",            label_nl: "Oorlog & Conflict",            label_fr: "Guerre & Conflit",            emoji: "⚔️",  color: "#fca5a5", border: "#f87171" },
  "crime-violence":          { label_en: "Crime & Violence",          label_nl: "Misdaad & Geweld",             label_fr: "Crime & Violence",            emoji: "🔫",  color: "#fdba74", border: "#fb923c" },
  "political-conflict":      { label_en: "Political Conflict",        label_nl: "Politiek Conflict",            label_fr: "Conflit Politique",           emoji: "🏛️",  color: "#d8b4fe", border: "#c084fc" },
  "economic-doom":           { label_en: "Economic Doom",             label_nl: "Economische Ellende",          label_fr: "Catastrophe Économique",      emoji: "📉",  color: "#fde047", border: "#facc15" },
  "disaster-accident":       { label_en: "Disaster & Accident",       label_nl: "Ramp & Ongeluk",               label_fr: "Catastrophe & Accident",      emoji: "🌊",  color: "#93c5fd", border: "#60a5fa" },
  "health-scare":            { label_en: "Health Scare",              label_nl: "Gezondheidsalarm",             label_fr: "Alerte Sanitaire",            emoji: "🦠",  color: "#86efac", border: "#4ade80" },
  "divisive-social":         { label_en: "Divisive & Social Tension", label_nl: "Verdeeldheid & Spanningen",    label_fr: "Tensions Sociales",           emoji: "⚡",  color: "#fcd34d", border: "#fbbf24" },
  "lgbtq-rights":            { label_en: "LGBTQ Rights",              label_nl: "LGBTQ-rechten",                label_fr: "Droits LGBTQ",                emoji: "🏳️‍🌈", color: "#f9a8d4", border: "#f472b6" },
  "divisive-racism":         { label_en: "Divisive & Racism",         label_nl: "Verdeeldheid & Racisme",       label_fr: "Racisme & Division",          emoji: "✊",  color: "#d6d3d1", border: "#a8a29e" },
  "sports-negative":         { label_en: "Sports & Competition",      label_nl: "Sport & Competitie",           label_fr: "Sport & Compétition",         emoji: "⚽",  color: "#bef264", border: "#84cc16" },
  "celebrity-entertainment": { label_en: "Celebrity & Entertainment", label_nl: "Celebrities & Entertainment",  label_fr: "Célébrités & Divertissement", emoji: "🎬",  color: "#f0abfc", border: "#d946ef" },
  "tech-ai-concern":         { label_en: "Tech & AI Anxiety",         label_nl: "Tech & AI-zorgen",             label_fr: "Inquiétudes Tech & IA",       emoji: "🤖",  color: "#a5f3fc", border: "#06b6d4" },
  "climate-environment":     { label_en: "Climate & Environment",     label_nl: "Klimaat & Milieu",             label_fr: "Climat & Environnement",      emoji: "🌍",  color: "#99f6e4", border: "#14b8a6" },
  "soft-news-filler":        { label_en: "Soft News & Filler",        label_nl: "Soft news & opvulling",        label_fr: "Info légère & remplissage",   emoji: "📰",  color: "#e2e8f0", border: "#94a3b8" },
  "other-negative":          { label_en: "Other Negative",            label_nl: "Overig Negatief",              label_fr: "Autre Négatif",               emoji: "😔",  color: "#d1d5db", border: "#9ca3af" }
} %}

<div class="page-header">
  <h1>
    <span class="t-en">The News We Skip 🚫</span>
    <span class="t-nl" style="display:none">Het nieuws dat we overslaan 🚫</span>
    <span class="t-fr" style="display:none">Les nouvelles que nous ignorons 🚫</span>
  </h1>
  <p>
    <span class="t-en">Every time we scan news sources, our AI reads the headline and filters out stories that are negative, anxiety-inducing, or just plain gloomy. This page shows what gets left behind — a transparent illustration of how skewed towards the negative most news coverage tends to be. The statistics below cover every article we have ever filtered out. The browsable list at the bottom shows the 1,000 most recent rejections.</span>
    <span class="t-nl" style="display:none">Elke keer dat we nieuwsbronnen scannen, leest onze AI de kop en filtert verhalen die negatief, angstaanjagend of gewoon somber zijn. Deze pagina toont wat er overblijft — een transparante illustratie van hoe sterk het nieuws naar het negatieve neigt. De statistieken hieronder omvatten elk artikel dat we ooit hebben gefilterd. De doorzoekbare lijst onderaan toont de 1.000 meest recente afwijzingen.</span>
    <span class="t-fr" style="display:none">Chaque fois que nous analysons des sources d'actualité, notre IA lit le titre et filtre les articles négatifs, anxiogènes ou simplement moroses. Cette page montre ce qui reste — une illustration transparente du biais négatif dominant dans les médias. Les statistiques ci-dessous couvrent chaque article que nous avons jamais filtré. La liste consultable en bas affiche les 1 000 rejets les plus récents.</span>
  </p>
</div>


{% if rejections.total_rejected == 0 %}
  <p class="empty">
    <span class="t-en">No data yet — the rejection log will appear here after the first fetch.</span>
    <span class="t-nl" style="display:none">Nog geen data — het logboek verschijnt hier na de eerste fetch.</span>
    <span class="t-fr" style="display:none">Pas encore de données — le journal apparaîtra ici après la première récupération.</span>
  </p>
{% else %}

  {% if rejections.exported_at %}
  <p class="updated">
    <span class="t-en">Last updated: {{ rejections.exported_at | truncate(10, true, "") }}</span>
    <span class="t-nl" style="display:none">Laatste update: {{ rejections.exported_at | truncate(10, true, "") }}</span>
    <span class="t-fr" style="display:none">Dernière mise à jour : {{ rejections.exported_at | truncate(10, true, "") }}</span>
  </p>
  {% endif %}

  <!-- Stats heading -->
  <h2 class="section-heading">
    <span class="t-en">All-time statistics — {{ rejections.total_rejected }} articles filtered</span>
    <span class="t-nl" style="display:none">Statistieken over alle tijd — {{ rejections.total_rejected }} artikelen gefilterd</span>
    <span class="t-fr" style="display:none">Statistiques globales — {{ rejections.total_rejected }} articles filtrés</span>
  </h2>

  <!-- Summary stats -->
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-num">{{ rejections.total_rejected }}</div>
      <div class="stat-lbl">
        <span class="t-en">articles filtered out</span>
        <span class="t-nl" style="display:none">artikels gefilterd</span>
        <span class="t-fr" style="display:none">articles filtrés</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-num">{{ rejections.sources_count }}</div>
      <div class="stat-lbl">
        <span class="t-en">news sources scanned</span>
        <span class="t-nl" style="display:none">nieuwsbronnen gescand</span>
        <span class="t-fr" style="display:none">sources analysées</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-num">{{ rejections.articles.length }}</div>
      <div class="stat-lbl">
        <span class="t-en">shown here</span>
        <span class="t-nl" style="display:none">hier weergegeven</span>
        <span class="t-fr" style="display:none">affichés ici</span>
      </div>
    </div>
  </div>

  <!-- Category breakdown chart -->
  {% if rejections.category_breakdown and rejections.category_breakdown.length > 0 %}
  <div class="breakdown-section">
    <div class="breakdown-title">
      <span class="t-en">What kind of negativity dominates the news</span>
      <span class="t-nl" style="display:none">Welk soort negativiteit domineert het nieuws</span>
      <span class="t-fr" style="display:none">Quel type de négativité domine l'actualité</span>
    </div>
    {% for row in rejections.category_breakdown %}
      {% set meta = catMeta[row.category] %}
      {% if meta %}
      {% set pct = (row.count / rejections.total_rejected * 100) | round %}
      <div class="breakdown-row">
        <div class="breakdown-label">
          {{ meta.emoji }}&nbsp;
          <span class="t-en">{{ meta.label_en }}</span>
          <span class="t-nl" style="display:none">{{ meta.label_nl }}</span>
          <span class="t-fr" style="display:none">{{ meta.label_fr }}</span>
        </div>
        <div class="breakdown-bar-wrap">
          <div class="breakdown-bar" style="width:{{ pct }}%; background-color:{{ meta.border }};"></div>
        </div>
        <div class="breakdown-count">{{ row.count }} ({{ pct }}%)</div>
      </div>
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}

  <!-- List heading -->
  <h2 class="section-heading">
    <span class="t-en">Most recent 1,000 skipped articles</span>
    <span class="t-nl" style="display:none">Meest recente 1.000 overgeslagen artikelen</span>
    <span class="t-fr" style="display:none">Les 1 000 articles ignorés les plus récents</span>
  </h2>

  <!-- Category filter pills -->
  {% if rejections.category_breakdown and rejections.category_breakdown.length > 0 %}
  <div class="filter-bar" id="cat-filter-bar">
    <button class="cat-pill active" onclick="filterCat('all', this)">
      <span class="t-en">All</span>
      <span class="t-nl" style="display:none">Alles</span>
      <span class="t-fr" style="display:none">Tout</span>
    </button>
    {% for row in rejections.category_breakdown %}
      {% set meta = catMeta[row.category] %}
      {% if meta %}
      <button class="cat-pill" onclick="filterCat('{{ row.category }}', this)" data-cat="{{ row.category }}">
        {{ meta.emoji }}&nbsp;
        <span class="t-en">{{ meta.label_en }}</span>
        <span class="t-nl" style="display:none">{{ meta.label_nl }}</span>
        <span class="t-fr" style="display:none">{{ meta.label_fr }}</span>
        ({{ row.count }})
      </button>
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}

  <!-- Pagination bar (top) -->
  <div class="pagination-bar" id="pagination-bar-top">
    <span class="page-size-label">
      <span class="t-en">Show</span>
      <span class="t-nl" style="display:none">Toon</span>
      <span class="t-fr" style="display:none">Afficher</span>
    </span>
    <select class="page-size-select" id="page-size-select" onchange="setPageSize(+this.value)">
      <option value="50">50</option>
      <option value="100" selected>100</option>
      <option value="250">250</option>
    </select>
    <button class="page-btn" id="prev-btn-top" onclick="changePage(-1)">&#8592;</button>
    <button class="page-btn" id="next-btn-top" onclick="changePage(+1)">&#8594;</button>
    <span class="page-info" id="page-info-top"></span>
  </div>

  <!-- Article list (JS-rendered) -->
  <div class="rejection-list" id="rejection-list"></div>

  <!-- Pagination bar (bottom) -->
  <div class="pagination-bar" id="pagination-bar-bottom" style="margin-top:1.25rem; margin-bottom:0;">
    <button class="page-btn" id="prev-btn-bottom" onclick="changePage(-1)">&#8592;</button>
    <button class="page-btn" id="next-btn-bottom" onclick="changePage(+1)">&#8594;</button>
    <span class="page-info" id="page-info-bottom"></span>
  </div>

{% endif %}

<script>
  var REJECTIONS = {{ rejections.articles | dump | safe }};
  var CAT_META   = {{ catMeta | dump | safe }};

  var activeCat   = 'all';
  var pageSize    = 100;
  var currentPage = 1;

  function escHtml(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function getFiltered() {
    if (activeCat === 'all') return REJECTIONS;
    return REJECTIONS.filter(function(r) { return r.category === activeCat; });
  }

  function renderPage() {
    var filtered   = getFiltered();
    var total      = filtered.length;
    var totalPages = Math.max(1, Math.ceil(total / pageSize));
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;

    var start = (currentPage - 1) * pageSize;
    var items = filtered.slice(start, start + pageSize);

    var lang = document.documentElement.getAttribute('data-lang') || 'en';

    var html = items.map(function(item) {
      var meta = CAT_META[item.category] || null;
      var borderStyle = meta ? 'border-left-color:' + meta.border + ';' : '';

      var badge = meta
        ? '<span class="cat-badge" style="color:' + meta.border + ';border-color:' + meta.border + ';background:' + meta.color + '20;">'
          + meta.emoji + '&nbsp;'
          + '<span class="t-en"' + (lang!=='en'?' style="display:none"':'') + '>' + meta.label_en + '</span>'
          + '<span class="t-nl"' + (lang!=='nl'?' style="display:none"':'') + '>' + meta.label_nl + '</span>'
          + '<span class="t-fr"' + (lang!=='fr'?' style="display:none"':'') + '>' + meta.label_fr + '</span>'
          + '</span>'
        : '';

      var fallbackReason = '<span class="t-en"' + (lang!=='en'?' style="display:none"':'') + '>does not fit positive news criteria</span>'
        + '<span class="t-nl"' + (lang!=='nl'?' style="display:none"':'') + '>past niet bij positief nieuws</span>'
        + '<span class="t-fr"' + (lang!=='fr'?' style="display:none"':'') + '>ne correspond pas aux critères de l\'actualité positive</span>';

      return '<div class="rejection-card" data-cat="' + escHtml(item.category) + '" style="' + borderStyle + '">'
        + '<p class="rejection-title"><a href="' + escHtml(item.url) + '" target="_blank" rel="noopener noreferrer" style="color:inherit;text-decoration:none;">' + escHtml(item.title) + '</a></p>'
        + '<div class="rejection-meta"><span>' + escHtml(item.source) + '</span><span>' + escHtml(item.date) + '</span>' + badge + '</div>'
        + '<p class="rejection-reason">' + (item.reason ? escHtml(item.reason) : fallbackReason) + '</p>'
        + '</div>';
    }).join('');

    document.getElementById('rejection-list').innerHTML = html;

    // Update both pagination bars
    var infoText = currentPage + ' / ' + totalPages;
    var isFirst = currentPage === 1;
    var isLast  = currentPage === totalPages;
    ['top','bottom'].forEach(function(side) {
      var infoEl = document.getElementById('page-info-' + side);
      var prevEl = document.getElementById('prev-btn-' + side);
      var nextEl = document.getElementById('next-btn-' + side);
      if (infoEl) infoEl.textContent = infoText;
      if (prevEl) prevEl.disabled = isFirst;
      if (nextEl) nextEl.disabled = isLast;
    });
  }

  function changePage(delta) {
    currentPage += delta;
    renderPage();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function setPageSize(n) {
    pageSize    = n;
    currentPage = 1;
    renderPage();
  }

  function filterCat(cat, btn) {
    activeCat   = cat;
    currentPage = 1;
    document.querySelectorAll('.cat-pill').forEach(function(b) { b.classList.remove('active'); });
    if (btn) btn.classList.add('active');
    renderPage();
  }

  // Initial render
  renderPage();

  // Restore saved language
  (function() {
    var lang = localStorage.getItem('positron-today-lang') || 'en';
    if (lang !== 'en') {
      var btn = document.querySelector('.nav-lang-btn[onclick*="' + lang + '"]');
      setLang(lang, btn);
    }
  })();
</script>
