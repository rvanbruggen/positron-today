---
permalink: /search-index.json
eleventyExcludeFromCollections: true
---
[{% for post in collections.posts %}{"title":{{ post.data.title | dump | safe }},"title_nl":{{ (post.data.title_nl if post.data.title_nl else post.data.title) | dump | safe }},"title_fr":{{ (post.data.title_fr if post.data.title_fr else post.data.title) | dump | safe }},"summary":{{ (post.data.summary if post.data.summary else "") | dump | safe }},"summary_nl":{{ (post.data.summary_nl if post.data.summary_nl else (post.data.summary if post.data.summary else "")) | dump | safe }},"summary_fr":{{ (post.data.summary_fr if post.data.summary_fr else (post.data.summary if post.data.summary else "")) | dump | safe }},"tags":"{% if post.data.tags and post.data.tags.length > 0 %}{{ post.data.tags | join(', ') }}{% elif post.data.topic %}{{ post.data.topic }}{% endif %}","source_name":{{ (post.data.source_name if post.data.source_name else "") | dump | safe }},"url":"{{ post.url | url }}","source_url":{{ (post.data.source_url if post.data.source_url else "") | dump | safe }},"date":"{{ post.date | dateTimeShort }}","emoji":{{ (post.data.emoji if post.data.emoji else "") | dump | safe }},"image_url":{{ (post.data.image_url if post.data.image_url else "") | dump | safe }}}{% if not loop.last %},{% endif %}
{% endfor %}]
