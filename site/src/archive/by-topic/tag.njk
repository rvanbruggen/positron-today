---
layout: base.njk
pagination:
  data: collections.tagsList
  size: 1
  alias: tag
permalink: "/archive/by-topic/{{ tag | slugify }}/"
eleventyComputed:
  title: "{{ tag }}"
  description: "Positive news tagged {{ tag }} on Positron Today — curated, AI-summarised, each story linked back to the original source."
---

<style>
  .tag-wrap { max-width: 1200px; }
  .tag-header { margin-bottom: 1.5rem; }
  .tag-header h1 {
    font-size: clamp(1.35rem, 5vw, 1.75rem);
    font-weight: 700;
    color: #78350f;
    margin-bottom: 0.25rem;
  }
  .tag-header p { font-size: 0.9rem; color: #b45309; }
  .tag-crumb {
    font-size: 0.8rem;
    color: #b45309;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .tag-crumb:hover { color: #78350f; }

  .tag-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .tag-card {
    position: relative;
    border-radius: 1rem;
    padding: 1.1rem;
    border: 2px solid transparent;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: transform 0.15s, box-shadow 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  @media (hover: hover) {
    .tag-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.10); }
  }

  .tag-card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    text-decoration: none;
  }
  .tag-card-permalink {
    position: relative; z-index: 2;
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px;
    color: inherit;
    opacity: 0.4;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .tag-card-permalink:hover { opacity: 1; }
  .tag-card-permalink svg { width: 14px; height: 14px; display: block; }

  .tag-card-img {
    width: calc(100% + 2.2rem);
    margin: -1.1rem -1.1rem 0.5rem;
    border-radius: 0.85rem 0.85rem 0 0;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }
  .tag-card-emoji { font-size: 1.4rem; }
  .tag-card-tags { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .tag-card-tag {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.7;
    color: inherit;
    text-decoration: none;
    position: relative;
    z-index: 2;
  }
  .tag-card-tag:hover { opacity: 1; text-decoration: underline; }
  .tag-card-title { font-size: 0.95rem; font-weight: 600; line-height: 1.4; }
  .tag-card-summary { font-size: 0.82rem; line-height: 1.55; opacity: 0.85; }
  .tag-card-meta {
    font-size: 0.7rem;
    margin-top: auto;
    padding-top: 0.5rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  .tag-card-meta > span:not(.tag-card-meta-right),
  .tag-card-meta-right > span { opacity: 0.6; }
  .tag-card-meta-right { display: inline-flex; align-items: center; gap: 0.4rem; }

  .card-yellow  { background:#fef9c3; border-color:#fde047; color:#713f12; }
  .card-orange  { background:#ffedd5; border-color:#fb923c; color:#7c2d12; }
  .card-rose    { background:#ffe4e6; border-color:#fb7185; color:#881337; }
  .card-purple  { background:#f3e8ff; border-color:#c084fc; color:#581c87; }
  .card-blue    { background:#dbeafe; border-color:#60a5fa; color:#1e3a5f; }
  .card-cyan    { background:#cffafe; border-color:#22d3ee; color:#164e63; }
  .card-teal    { background:#ccfbf1; border-color:#2dd4bf; color:#134e4a; }
  .card-green   { background:#dcfce7; border-color:#4ade80; color:#14532d; }
  .card-lime    { background:#ecfccb; border-color:#a3e635; color:#365314; }
  .card-pink    { background:#fce7f3; border-color:#f472b6; color:#831843; }
</style>

<div class="tag-wrap">
  <a href="/archive/by-topic/" class="tag-crumb">
    &larr; <span class="t-en">All topics</span>
    <span class="t-nl" style="display:none">Alle onderwerpen</span>
    <span class="t-fr" style="display:none">Tous les sujets</span>
  </a>

  <div class="tag-header">
    <h1>{{ tag }}</h1>
    {%- set tagCount = (collections.tagCounts[tag] or 0) -%}
    <p>
      <span class="t-en">{{ tagCount }} {{ "story" if tagCount == 1 else "stories" }} tagged "{{ tag }}".</span>
      <span class="t-nl" style="display:none">{{ tagCount }} {{ "verhaal" if tagCount == 1 else "verhalen" }} met onderwerp "{{ tag }}".</span>
      <span class="t-fr" style="display:none">{{ tagCount }} {{ "article" if tagCount == 1 else "articles" }} avec le sujet "{{ tag }}".</span>
    </p>
  </div>

  <div class="tag-grid">
    {% for post in collections.posts %}
      {% if post.data.tags and post.data.tags.length > 0 %}
        {% set cardTags = post.data.tags %}
      {% elif post.data.topic %}
        {% set cardTags = [post.data.topic] %}
      {% else %}
        {% set cardTags = [] %}
      {% endif %}
      {% if tag in cardTags %}
        {% set firstTag = cardTags[0] %}
      <article class="tag-card card-{{ firstTag | topicColor }}">
        <a class="tag-card-link"
           href="{{ post.data.source_url }}"
           target="_blank"
           rel="noopener noreferrer"
           aria-label="{{ post.data.title | striptags | replace('\"','') }} — read at {{ post.data.source_name }} (opens in a new tab)"></a>

        {% if post.data.image_url %}<img class="tag-card-img" src="{{ post.data.image_url }}" alt="{{ post.data.title | striptags | replace('\"','') }}" loading="lazy" onerror="this.style.display='none'">{% endif %}
        <div class="tag-card-emoji">{{ post.data.emoji }}</div>
        <div class="tag-card-tags">
          {% for t in cardTags %}<a class="tag-card-tag" href="/archive/by-topic/{{ t | slugify }}/">{{ t }}</a>{% if not loop.last %} <span class="tag-card-tag" aria-hidden="true">&middot;</span> {% endif %}{% endfor %}
        </div>
        <div class="tag-card-title">
          <span class="t-en">{{ post.data.title }}</span>
          <span class="t-nl" style="display:none">{{ post.data.title_nl if post.data.title_nl else post.data.title }}</span>
          <span class="t-fr" style="display:none">{{ post.data.title_fr if post.data.title_fr else post.data.title }}</span>
        </div>
        {% if post.data.summary %}
          <div class="tag-card-summary">
            <span class="t-en">{{ post.data.summary | truncate(180, true, "…") }}</span>
            <span class="t-nl" style="display:none">{{ (post.data.summary_nl if post.data.summary_nl else post.data.summary) | truncate(180, true, "…") }}</span>
            <span class="t-fr" style="display:none">{{ (post.data.summary_fr if post.data.summary_fr else post.data.summary) | truncate(180, true, "…") }}</span>
          </div>
        {% endif %}
        <div class="tag-card-meta">
          <span>{{ post.data.source_name }}</span>
          <span class="tag-card-meta-right">
            <span>{{ post.date | dateShort }}</span>
            <a class="tag-card-permalink" href="{{ post.url | url }}" title="Open on Positron Today" aria-label="Open on Positron Today">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" aria-hidden="true">
                <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="currentColor" stroke-width="8"/>
                <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="currentColor" stroke-width="8" transform="rotate(60 50 50)"/>
                <ellipse cx="50" cy="50" rx="46" ry="16" fill="none" stroke="currentColor" stroke-width="8" transform="rotate(120 50 50)"/>
                <circle cx="50" cy="50" r="12" fill="currentColor"/>
              </svg>
            </a>
          </span>
        </div>
      </article>
      {% endif %}
    {% endfor %}
  </div>
</div>
