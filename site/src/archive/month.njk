---
layout: base.njk
eleventyComputed:
  title: "{{ month.key | dateMonthLabel }}"
pagination:
  data: collections.postsByMonth
  size: 1
  alias: month
permalink: "archive/{{ month.key | replace('-', '/') }}/"
---

<style>
  /* Card layout — mirrors index.njk */
  .page-header { margin-bottom: 1.25rem; }
  .page-header h1 { font-size: clamp(1.35rem, 5vw, 1.75rem); font-weight: 700; color: #78350f; margin-bottom: 0.25rem; }
  .page-header p { font-size: 0.875rem; color: #b45309; }

  .card-grid { columns: 1; column-gap: 1rem; }
  @media (min-width: 480px) { .card-grid { columns: 2; } }
  @media (min-width: 700px) { .card-grid { columns: 3; column-gap: 1.25rem; } }

  .card {
    break-inside: avoid; margin-bottom: 1rem;
    border-radius: 1rem; padding: 1.1rem; border: 2px solid transparent;
    text-decoration: none; display: flex; flex-direction: column; gap: 0.4rem;
    transition: transform 0.15s, box-shadow 0.15s; -webkit-tap-highlight-color: transparent;
  }
  @media (min-width: 640px) { .card { padding: 1.25rem; gap: 0.5rem; margin-bottom: 1.25rem; } }
  @media (hover: hover) { .card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.10); } }

  .card-emoji { font-size: 1.5rem; }
  .card-tags { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .card-tag { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.04em; opacity: 0.7; }
  .card-title { font-size: 0.95rem; font-weight: 600; line-height: 1.4; }
  .card-summary { font-size: 0.825rem; line-height: 1.55; opacity: 0.85; }
  .card-meta { font-size: 0.7rem; opacity: 0.6; margin-top: auto; padding-top: 0.5rem; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.25rem; }
  .card-date-wrap { text-align: right; line-height: 1.3; }
  .card-date-site { font-size: 0.6rem; opacity: 0.55; }

  .card-yellow  { background:#fef9c3; border-color:#fde047; color:#713f12; }
  .card-orange  { background:#ffedd5; border-color:#fb923c; color:#7c2d12; }
  .card-rose    { background:#ffe4e6; border-color:#fb7185; color:#881337; }
  .card-purple  { background:#f3e8ff; border-color:#c084fc; color:#581c87; }
  .card-blue    { background:#dbeafe; border-color:#60a5fa; color:#1e3a5f; }
  .card-cyan    { background:#cffafe; border-color:#22d3ee; color:#164e63; }
  .card-teal    { background:#ccfbf1; border-color:#2dd4bf; color:#134e4a; }
  .card-green   { background:#dcfce7; border-color:#4ade80; color:#14532d; }
  .card-lime    { background:#ecfccb; border-color:#a3e635; color:#365314; }
  .card-pink    { background:#fce7f3; border-color:#f472b6; color:#831843; }

  /* Archive navigation */
  .archive-back { font-size: 0.85rem; margin-bottom: 1.5rem; }
  .archive-back a { color: #b45309; text-decoration: none; font-weight: 600; border-bottom: 1.5px solid #fde68a; padding-bottom: 1px; }
  .archive-back a:hover { border-color: #f59e0b; }
  .archive-nav { display: flex; justify-content: space-between; align-items: center; margin-top: 2.25rem; }
  .archive-nav a {
    color: #78350f; text-decoration: none; font-size: 0.875rem; font-weight: 600;
    padding: 0.5rem 1.1rem; border: 1.5px solid #fde68a; border-radius: 99px;
    background: white; transition: border-color 0.15s;
  }
  .archive-nav a:hover { border-color: #fbbf24; }
  .archive-nav .spacer { display: inline-block; width: 1px; }
</style>

<div class="archive-back">
  <a href="{{ '/archive/' | url }}">
    ← <span class="t-en">Archive</span>
    <span class="t-nl" style="display:none">Archief</span>
    <span class="t-fr" style="display:none">Archives</span>
  </a>
</div>

<div class="page-header">
  <h1>
    <span class="t-en">{{ month.key | dateMonthLabel }}</span>
    <span class="t-nl" style="display:none">{{ month.key | dateMonthLabelNl }}</span>
    <span class="t-fr" style="display:none">{{ month.key | dateMonthLabelFr }}</span>
  </h1>
  <p>
    <span class="t-en">{{ month.posts.length }} article{% if month.posts.length != 1 %}s{% endif %} from this month.</span>
    <span class="t-nl" style="display:none">{{ month.posts.length }} artikel{% if month.posts.length != 1 %}en{% endif %} uit deze maand.</span>
    <span class="t-fr" style="display:none">{{ month.posts.length }} article{% if month.posts.length != 1 %}s{% endif %} de ce mois.</span>
  </p>
</div>

<div class="card-grid">
  {% for post in month.posts %}
    {% if post.data.tags and post.data.tags.length > 0 %}
      {% set cardTags = post.data.tags %}
    {% elif post.data.topic %}
      {% set cardTags = [post.data.topic] %}
    {% else %}
      {% set cardTags = [] %}
    {% endif %}
    {% set firstTag = cardTags[0] if cardTags.length > 0 else "" %}
    <a
      href="{{ post.url | url }}"
      class="card card-{{ firstTag | topicColor }}"
      data-tags="{{ cardTags | join(',') }}"
    >
      <div class="card-emoji">{{ post.data.emoji }}</div>
      <div class="card-tags">
        {% for tag in cardTags %}<span class="card-tag">{{ tag }}{% if not loop.last %} · {% endif %}</span>{% endfor %}
      </div>
      <div class="card-title">
        <span class="t-en">{{ post.data.title }}</span>
        <span class="t-nl" style="display:none">{{ post.data.title_nl if post.data.title_nl else post.data.title }}</span>
        <span class="t-fr" style="display:none">{{ post.data.title_fr if post.data.title_fr else post.data.title }}</span>
      </div>
      {% if post.data.summary %}
      <div class="card-summary">
        <span class="t-en">{{ post.data.summary }}</span>
        <span class="t-nl" style="display:none">{{ post.data.summary_nl if post.data.summary_nl else post.data.summary }}</span>
        <span class="t-fr" style="display:none">{{ post.data.summary_fr if post.data.summary_fr else post.data.summary }}</span>
      </div>
      {% endif %}
      <div class="card-meta">
        <span>{{ post.data.source_name }}</span>
        {% if post.data.source_pub_date %}
          <span class="card-date-wrap">
            <span title="Original publication date">{{ post.data.source_pub_date | dateShort }}</span><br>
            <span class="card-date-site" title="Published on Positiviteiten">on site {{ post.date | dateShort }}</span>
          </span>
        {% else %}
          <span class="card-date-site" title="Published on Positiviteiten">on site {{ post.date | dateShort }}</span>
        {% endif %}
      </div>
    </a>
  {% endfor %}
</div>

<div class="archive-nav">
  {% if pagination.href.previous %}
    <a href="{{ pagination.href.previous }}">
      ← <span class="t-en">Newer</span>
      <span class="t-nl" style="display:none">Nieuwer</span>
      <span class="t-fr" style="display:none">Plus récent</span>
    </a>
  {% else %}
    <span class="spacer"></span>
  {% endif %}
  {% if pagination.href.next %}
    <a href="{{ pagination.href.next }}">
      <span class="t-en">Older</span>
      <span class="t-nl" style="display:none">Ouder</span>
      <span class="t-fr" style="display:none">Plus ancien</span>
      →
    </a>
  {% else %}
    <span class="spacer"></span>
  {% endif %}
</div>
