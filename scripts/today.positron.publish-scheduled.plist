<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>today.positron.publish-scheduled</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/rikvanbruggen/Documents/GitHub/positiviteiten/scripts/publish-scheduled.sh</string>
  </array>

  <!-- Run every hour -->
  <key>StartInterval</key>
  <integer>3600</integer>

  <!-- Also run once when loaded (catches anything missed while Mac was off) -->
  <key>RunAtLoad</key>
  <true/>

  <!-- Keep logs -->
  <key>StandardOutPath</key>
  <string>/Users/rikvanbruggen/Library/Logs/positron-publish-scheduled.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/rikvanbruggen/Library/Logs/positron-publish-scheduled.log</string>
</dict>
</plist>
